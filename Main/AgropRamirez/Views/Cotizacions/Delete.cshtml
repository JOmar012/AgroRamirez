@model AgropRamirez.Models.Cotizacion

@{
    ViewData["Title"] = "Eliminar Cotización";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Eliminar Cotización</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Cotizaciones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header-delete text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-trash"></i> Eliminar Cotización
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <!-- Ícono lateral -->
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center">
                                <i class="bi bi-file-earmark-text zoom-avatar-delete text-danger" style="font-size: 6rem;"></i>
                            </div>
                        </div>

                        <!-- Contenido -->
                        <div class="col-md-8">
                            <h5 class="text-danger mb-3">
                                <i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación
                            </h5>

                            <p class="text-muted">
                                ¿Estás seguro de que deseas eliminar esta cotización? Revisa la información antes de continuar.
                            </p>

                            <!-- Información de la cotización -->
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Fecha de Cotización</dt>
                                <dd class="col-sm-8">@Model.FechaCotizacion.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Válido Hasta</dt>
                                <dd class="col-sm-8">@Model.ValidoHasta?.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Total</dt>
                                <dd class="col-sm-8">S/ @Model.Total.ToString("0.00")</dd>

                                <dt class="col-sm-4">Estado</dt>
                                <dd class="col-sm-8">@Model.Estado</dd>

                                <dt class="col-sm-4">Cliente</dt>
                                <dd class="col-sm-8">@($"{Model.Usuario?.Nombre} {Model.Usuario?.Apellido}")</dd>
                            </dl>
  

                        </div>

                    </div>

                    <hr class="my-4" />

                    <!-- Tabla de productos cotizados -->
                    <h5 class="fw-bold text-secondary mb-3 text-center">
                        <i class="bi bi-bag-check"></i> Productos Cotizados
                    </h5>

                    @if (Model.CotizacionDetalles != null && Model.CotizacionDetalles.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-custom align-middle text-center">
                                <thead>
                                    <tr>
                                        <th><i class="bi bi-box-seam"></i> Producto</th>
                                        <th><i class="bi bi-cash"></i> Precio Unitario</th>
                                        <th><i class="bi bi-plus-slash-minus"></i> Cantidad</th>
                                        <th><i class="bi bi-calculator"></i> Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var det in Model.CotizacionDetalles)
                                    {
                                        <tr>
                                            <td class="text-start">
                                                <i class="bi bi-caret-right-fill text-info"></i> @det.Producto?.Nombre
                                            </td>
                                            <td>S/ @det.PrecioUnitario.ToString("0.00")</td>
                                            <td>@det.Cantidad</td>
                                            <td class="fw-bold">S/ @((det.Cantidad * det.PrecioUnitario).ToString("0.00"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary text-center mt-3">
                            <i class="bi bi-info-circle"></i> No hay productos asociados a esta cotización.
                        </div>
                    }

                    <!-- Advertencia final -->
                    <div class="alert alert-warning mt-4 mb-0 text-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        ¿Estás seguro de que deseas eliminar esta cotización?<br />
                        <span class="fw-semibold">Esta acción no se podrá deshacer.</span>
                    </div>

                    <!-- Formulario de eliminación -->
                    <form asp-action="Delete" method="post" class="mt-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="CotizacionId" />
                        <div class="d-flex justify-content-between">
                            <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash-fill"></i> Eliminar
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>