    @model AgropRamirez.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Editar Producto</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Productos</a></li>
                <li class="breadcrumb-item active" aria-current="page">Editar</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Encabezado -->
                <div class="card-header custom-header-edit text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-pencil-square"></i> Editar Producto
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="ProductoId" />

                        <div class="row align-items-start">
                            <!-- Imagen actual (reemplazable) -->
                            <div class="col-md-4 text-center mb-4 mb-md-0">
                                <img id="productImage"
                                     src="@(!string.IsNullOrEmpty(Model.Imagen) ? Model.Imagen : Url.Content("~/img/no-image.png"))"
                                     alt="Imagen del producto"
                                     class="img-fluid rounded-3 shadow-sm"
                                     style="width:100%; height:auto; object-fit:cover;" />

                                <!-- Cargar nueva imagen -->
                                <div class="mt-3 text-start">
                                    <label asp-for="ImagenFile" class="form-label fw-semibold">
                                        <i class="bi bi-upload"></i> Cambiar imagen
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">
                                            <i class="bi bi-upload text-warning"></i>
                                        </span>
                                        <input asp-for="ImagenFile"
                                               type="file"
                                               class="form-control"
                                               accept="image/*"
                                               onchange="replaceImage(event)" />
                                    </div>
                                    <span asp-validation-for="ImagenFile" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Campos del formulario -->
                            <div class="col-md-8">
                                <!-- Nombre -->
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label fw-semibold">
                                        <i class="bi bi-box"></i> Nombre
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-box"></i></span>
                                        <input asp-for="Nombre" class="form-control" />
                                    </div>
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>

                                <!-- Descripción -->
                                <div class="mb-3">
                                    <label asp-for="Descripcion" class="form-label fw-semibold">
                                        <i class="bi bi-card-text"></i> Descripción
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                                    </div>
                                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                                </div>

                                <!-- Precio Unitario -->
                                <div class="mb-3">
                                    <label asp-for="Precio" class="form-label fw-semibold">
                                        <i class="bi bi-currency-dollar"></i> Precio Unitario
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-currency-dollar"></i></span>
                                        <input asp-for="Precio" class="form-control" type="number" step="0.01" />
                                    </div>
                                    <span asp-validation-for="Precio" class="text-danger"></span>
                                </div>

                                <!-- Precio por Mayor -->
                                <div class="mb-3">
                                    <label asp-for="PrecioPorMayor" class="form-label fw-semibold">
                                        <i class="bi bi-cart4"></i> Precio por Mayor
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-cart4"></i></span>
                                        <input asp-for="PrecioPorMayor" class="form-control" type="number" step="0.01" />
                                    </div>
                                    <span asp-validation-for="PrecioPorMayor" class="text-danger"></span>
                                </div>

                                <!-- Umbral Mayorista -->
                                <div class="mb-3">
                                    <label asp-for="UmbralMayorista" class="form-label fw-semibold">
                                        <i class="bi bi-123"></i> Umbral Mayorista
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-123"></i></span>
                                        <input asp-for="UmbralMayorista" class="form-control" type="number" />
                                    </div>
                                    <span asp-validation-for="UmbralMayorista" class="text-danger"></span>
                                </div>

                                <!-- Stock -->
                                <div class="mb-3">
                                    <label asp-for="Stock" class="form-label fw-semibold">
                                        <i class="bi bi-box-seam"></i> Stock
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-box-seam"></i></span>
                                        <input asp-for="Stock" class="form-control" type="number" />
                                    </div>
                                    <span asp-validation-for="Stock" class="text-danger"></span>
                                </div>

                                <!-- Categoría -->
                                <div class="mb-3">
                                    <label asp-for="CategoriaId" class="form-label fw-semibold">
                                        <i class="bi bi-tags"></i> Categoría
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-tags"></i></span>
                                        <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId"></select>
                                    </div>
                                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning text-white px-4">
                                <i class="bi bi-check-circle"></i> Guardar cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function replaceImage(event) {
            const file = event.target.files[0];
            const image = document.getElementById('productImage');
            if (file) {
                const reader = new FileReader();
                reader.onload = e => {
                    image.src = e.target.result; // Reemplaza la imagen actual
                };
                reader.readAsDataURL(file);
            }
        }
    </script>
}