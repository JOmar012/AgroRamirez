@model AgropRamirez.Models.Producto
@{
    ViewData["Title"] = "Crear Producto";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Registrar Producto</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Productos</a></li>
                <li class="breadcrumb-item active" aria-current="page">Crear</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-box-seam"></i> Registrar Producto
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row align-items-start">

                            <!-- Avatar / Vista previa -->
                            <div class="col-md-4 text-center mb-4 mb-md-0">
                                <div class="d-flex flex-column align-items-center justify-content-start w-100">
                                    <!-- Contenedor principal de imagen / avatar -->
                                    <div id="avatar-container" class="zoom-avatar-product mb-3">
                                        <i class="fas fa-horse" id="avatar-icon"></i>
                                        <img id="preview" src="#" alt="Vista previa"
                                             style="display:none; width:100%; height:100%; object-fit:cover; border-radius:12px;" />
                                    </div>

                                    <!-- Campo para subir imagen -->
                                    <div class="w-100">
                                        <label asp-for="ImagenFile" class="form-label fw-semibold d-block text-start">
                                            <i class="bi bi-image"></i> Imagen del producto
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-upload text-success"></i>
                                            </span>
                                            <input asp-for="ImagenFile"
                                                   type="file"
                                                   class="form-control"
                                                   accept="image/*"
                                                   onchange="previewImage(event)" />
                                        </div>
                                        <span asp-validation-for="ImagenFile" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Formulario -->
                            <div class="col-md-8">
                                <!-- Nombre -->
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label fw-semibold">
                                        <i class="bi bi-box"></i> Nombre
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-box"></i></span>
                                        <input asp-for="Nombre" class="form-control" />
                                    </div>
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>

                                <!-- Descripción -->
                                <div class="mb-3">
                                    <label asp-for="Descripcion" class="form-label fw-semibold">
                                        <i class="bi bi-card-text"></i> Descripción
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                        <input asp-for="Descripcion" class="form-control" />
                                    </div>
                                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                                </div>

                                <!-- Precio -->
                                <div class="mb-3">
                                    <label asp-for="Precio" class="form-label fw-semibold">
                                        <i class="bi bi-currency-dollar"></i> Precio Unitario
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-currency-dollar"></i></span>
                                        <input asp-for="Precio" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Precio" class="text-danger"></span>
                                </div>

                                <!-- Precio por mayor -->
                                <div class="mb-3">
                                    <label asp-for="PrecioPorMayor" class="form-label fw-semibold">
                                        <i class="bi bi-cart4"></i> Precio por Mayor
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-cart4"></i></span>
                                        <input asp-for="PrecioPorMayor" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="PrecioPorMayor" class="text-danger"></span>
                                </div>

                                <!-- Umbral mayorista -->
                                <div class="mb-3">
                                    <label asp-for="UmbralMayorista" class="form-label fw-semibold">
                                        <i class="bi bi-123"></i> Umbral Mayorista
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-123"></i></span>
                                        <input asp-for="UmbralMayorista" class="form-control" type="number" placeholder="Ej: 10" />
                                    </div>
                                    <span asp-validation-for="UmbralMayorista" class="text-danger"></span>
                                </div>

                                <!-- Stock -->
                                <div class="mb-3">
                                    <label asp-for="Stock" class="form-label fw-semibold">
                                        <i class="bi bi-box-seam"></i> Stock
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-box-seam"></i></span>
                                        <input asp-for="Stock" class="form-control" type="number" />
                                    </div>
                                    <span asp-validation-for="Stock" class="text-danger"></span>
                                </div>

                                <!-- Imagen -->
                                @* <div class="mb-3">
                                    <label asp-for="ImagenFile" class="form-label fw-semibold">
                                        <i class="bi bi-image"></i> Imagen del producto
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-upload"></i></span>
                                        <input asp-for="ImagenFile" type="file" class="form-control" accept="image/*" onchange="previewImage(event)" />
                                    </div>
                                    <span asp-validation-for="ImagenFile" class="text-danger"></span>
                                </div> *@

                                <!-- Categoría -->
                                <div class="mb-3">
                                    <label asp-for="CategoriaId" class="form-label fw-semibold">
                                        <i class="bi bi-tags"></i> Categoría
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-tags"></i></span>
                                        <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId"></select>
                                    </div>
                                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle"></i> Registrar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            const avatar = document.getElementById('avatar-icon');
            const preview = document.getElementById('preview');

            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.style.display = "block";
                    avatar.style.display = "none"; // Oculta el ícono del caballo
                };
                reader.readAsDataURL(file);
            } else {
                preview.style.display = "none";
                avatar.style.display = "block"; // Muestra el ícono si no hay imagen
            }
        }
    </script>
}