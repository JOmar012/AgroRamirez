@model AgropRamirez.Models.Pago
@{
    ViewData["Title"] = "Detalle del Pago";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Detalle del Pago</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Pagos</a></li>
                <li class="breadcrumb-item active" aria-current="page">Detalle</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header-details text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-file-earmark-text"></i> Información del Pago
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <!-- Ícono lateral -->
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center">
                                <i class="bi bi-wallet2 zoom-avatar-details text-dark"></i>
                            </div>
                        </div>

                        <!-- Información -->
                        <div class="col-md-8">
                            <div class="fs-5">
                                <p><i class="bi bi-calendar-date me-2 text-success"></i><strong>Fecha de Pago:</strong> @Model.FechaPago.ToString("dd/MM/yyyy")</p>
                                <p><i class="bi bi-cash-stack me-2 text-success"></i><strong>Monto:</strong> S/ @Model.Monto.ToString("0.00")</p>
                                <p><i class="bi bi-credit-card me-2 text-success"></i><strong>Método de Pago:</strong> @Model.MetodoPago</p>
                                <p><i class="bi bi-check2-circle me-2 text-success"></i><strong>Estado:</strong> @Model.Estado</p>
                                <p><i class="bi bi-receipt me-2 text-success"></i><strong>Pedido:</strong> @Model.Pedido.FechaPedido.ToString("dd/MM/yyyy")</p>
                                <p><i class="bi bi-person-fill me-2 text-success"></i><strong>Cliente:</strong> @($"{Model.Usuario?.Nombre} {Model.Usuario?.Apellido}")</p>
                            </div>

                            <!-- Botones -->
                            <div class="d-flex justify-content-between mt-4">
                                <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                                    <i class="bi bi-arrow-left-circle"></i> Volver
                                </a>
                                <a asp-action="Edit" asp-route-id="@Model?.PagoId" class="btn btn-success px-4 text-white">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>