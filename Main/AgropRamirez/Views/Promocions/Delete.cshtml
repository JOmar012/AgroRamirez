@model AgropRamirez.Models.Promocion

@{
    ViewData["Title"] = "Eliminar Promoción";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Eliminar Promoción</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Promociones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4 detalles-promocion">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Encabezado -->
                <div class="card-header custom-header-delete text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-trash-fill me-2"></i> Eliminar Promoción
                    </h4>
                </div>

                <!-- Cuerpo -->
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <!-- Imagen -->
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="zoom-image">
                                @if (!string.IsNullOrEmpty(Model.Imagen))
                                {
                                    <img src="@Model.Imagen" alt="Imagen de la promoción"
                                         class="img-fluid rounded-3 shadow-sm"
                                         style="width:100%; height:100%; object-fit:cover;" />
                                }
                                else
                                {
                                    <img src="~/img/no-image.png" alt="Sin imagen"
                                         class="img-fluid rounded-3 shadow-sm opacity-50"
                                         style="width:100%; height:100%; object-fit:cover;" />
                                }
                            </div>
                        </div>

                        <!-- Información -->
                        <div class="col-md-8">
                            <h3 class="fw-bold text-dark mb-2">@Model.Nombre</h3>
                            <p class="text-muted mb-4">@Model.Descripcion</p>

                            <div>
                                <p><i class="bi bi-calendar-event me-2 text-danger"></i><strong>Fecha Inicio:</strong> @Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</p>
                                <p><i class="bi bi-calendar-event-fill me-2 text-danger"></i><strong>Fecha Fin:</strong> @Model.FechaFin.ToString("dd/MM/yyyy HH:mm")</p>
                                <p><i class="bi bi-percent me-2 text-danger"></i><strong>Descuento:</strong> @Model.Descuento.ToString("0.#")%</p>
                            </div>
                        </div>
                    </div>

                    <!-- Lista de productos incluidos -->
                    <div class="mt-5">
                        <h5 class="fw-bold mb-3 text-dark">
                            <i class="bi bi-box-seam"></i> Productos incluidos
                        </h5>

                        @if (Model.Productos != null && Model.Productos.Any())
                        {
                            <ul class="list-group shadow-sm">
                                @foreach (var prod in Model.Productos)
                                {
                                    <li class="list-group-item d-flex align-items-center">
                                        <img src="@prod.Imagen" alt="@prod.Nombre"
                                             class="rounded-circle me-3"
                                             style="width:50px; height:50px; object-fit:cover;" />
                                        <div>
                                            <strong>@prod.Nombre</strong><br />
                                            <span class="text-muted">S/ @prod.Precio</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted fst-italic">No hay productos asociados a esta promoción.</p>
                        }
                    </div>

                    <!-- Advertencia -->
                    <div class="alert alert-danger d-flex align-items-center mt-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div>
                            ¿Estás seguro de que deseas eliminar esta promoción? <br />
                            <strong>Esta acción no se puede deshacer.</strong>
                        </div>
                    </div>

                    <!-- Botones -->
                    <form asp-action="Delete" method="post" class="mt-3 d-flex justify-content-center gap-3">
                        <input type="hidden" asp-for="PromocionId" />
                        <button type="submit" class="btn btn-danger px-4 fw-bold">
                            <i class="bi bi-trash-fill"></i> Eliminar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold">
                            <i class="bi bi-arrow-left-circle"></i> Cancelar
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>