@model AgropRamirez.ViewModels.PromocionCreateViewModel

@{
    ViewData["Title"] = "Crear Promoción";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Registrar Promoción</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Promociones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Crear</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header bg-white text-center py-3 border-bottom">
                    <h4 class="mb-0 fw-bold text-white">
                        <i class="bi bi-gift-fill"></i> Registrar Promoción
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>


                        <div class="row align-items-start">
                            <!-- Columna Izquierda: Imagen -->
                            <div class="col-md-4 text-center mb-4 mb-md-0">
                                <div class="d-flex flex-column align-items-center justify-content-start w-100">
                                    <!-- Contenedor de avatar -->
                                    <div id="avatar-container" class="zoom-avatar-product mb-3">
                                        <i class="bi bi-gift-fill" id="avatar-icon"></i>
                                        <img id="preview" src="#" alt="Vista previa"
                                             style="display:none; width:100%; height:100%; object-fit:cover; border-radius:12px;" />
                                    </div>

                                    <!-- Campo para subir imagen -->
                                    <div class="w-100">
                                        <label asp-for="ImagenFile" class="form-label fw-semibold d-block text-start">
                                            <i class="bi bi-image"></i> Imagen de la promoción
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-upload text-danger"></i>
                                            </span>
                                            <input asp-for="ImagenFile"
                                                   type="file"
                                                   class="form-control"
                                                   accept="image/*"
                                                   onchange="previewImage(event)" />
                                        </div>
                                        <span asp-validation-for="ImagenFile" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Columna Derecha: Formulario -->
                            <div class="col-md-8">
                                <!-- Nombre -->
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label fw-semibold">
                                        <i class="bi bi-type"></i> Nombre
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-type"></i></span>
                                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Promoción de verano" />
                                    </div>
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>

                                <!-- Descripción -->
                                <div class="mb-3">
                                    <label asp-for="Descripcion" class="form-label fw-semibold">
                                        <i class="bi bi-card-text"></i> Descripción
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-card-text"></i></span>
                                        <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Describe la promoción"></textarea>
                                    </div>
                                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                                </div>

                                <!-- Fechas -->
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="FechaInicio" class="form-label fw-semibold">
                                            <i class="bi bi-calendar-event"></i> Fecha Inicio
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="bi bi-calendar-event"></i></span>
                                            <input asp-for="FechaInicio" class="form-control" type="datetime-local" />
                                        </div>
                                        <span asp-validation-for="FechaInicio" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label asp-for="FechaFin" class="form-label fw-semibold">
                                            <i class="bi bi-calendar-event-fill"></i> Fecha Fin
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="bi bi-calendar-event-fill"></i></span>
                                            <input asp-for="FechaFin" class="form-control" type="datetime-local" />
                                        </div>
                                        <span asp-validation-for="FechaFin" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Descuento -->
                                <div class="mb-3">
                                    <label asp-for="Descuento" class="form-label fw-semibold">
                                        <i class="bi bi-percent"></i> Descuento (%)
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-percent"></i></span>
                                        <input asp-for="Descuento" class="form-control" type="number" step="0.01" placeholder="Ej: 10 o 20" />
                                    </div>
                                    <span asp-validation-for="Descuento" class="text-danger"></span>
                                </div>

                                <!-- Productos -->
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">
                                        <i class="bi bi-box-seam"></i> Seleccionar Productos
                                    </label>
                                    <div class="list-group" style="max-height: 220px; overflow-y: auto;">
                                        @foreach (var prod in (IEnumerable<AgropRamirez.Models.Producto>)ViewBag.Productos)
                                        {
                                            <label class="list-group-item d-flex align-items-center">
                                                <input type="checkbox" name="ProductosSeleccionados" value="@prod.ProductoId" class="form-check-input me-2" />
                                                <img src="@prod.Imagen" alt="@prod.Nombre"
                                                     class="rounded-circle me-2"
                                                     style="width:40px; height:40px; object-fit:cover;" />
                                                <span>@prod.Nombre (@prod.Precio.ToString("C"))</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle"></i> Registrar
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            const avatar = document.getElementById('avatar-icon');
            const preview = document.getElementById('preview');

            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.style.display = "block";
                    avatar.style.display = "none"; // Oculta el ícono por defecto 🎁
                };
                reader.readAsDataURL(file);
            } else {
                preview.style.display = "none";
                avatar.style.display = "block"; // Muestra el ícono nuevamente
            }
        }
    </script>
}