@model IEnumerable<AgropRamirez.Models.Carrito>

@{
    ViewData["Title"] = "Carrito de Compras";
}

<!-- 🌄 Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn"
     data-wow-delay="0.1s"
     style="background: linear-gradient(rgba(0,0,0,.5), rgba(0,0,0,.5)), url('/img/Campos.jpg') center center/cover no-repeat;">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">
            <i class="bi bi-cart4"></i> Carrito de Compras
        </h1>
    </div>
</div>


<div class="container mb-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">
            <!-- 🔹 Encabezado -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">
                    <i class="bi bi-cart4 text-warning"></i> Lista de Carritos
                </h4>
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-bag-plus-fill"></i> Nuevo Carrito
                </a>
            </div>


            <!-- Buscador -->
            <form method="get" class="mb-3">
                <div class="row g-2 bg-light p-3 rounded-3">

                    <div class="col-md-10">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-search"></i> Buscar por usuario o fecha
                        </label>
                        <input type="text" id="txtBuscar" name="busqueda"
                               value="@ViewBag.Busqueda"
                               class="form-control"
                               placeholder="Ej: Carlos, Pérez, 2024-01-12..." />
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Buscar
                        </button>
                    </div>

                </div>
            </form>

            <!-- 🔹 Tabla -->
            <div class="table-responsive">
                <table class="table table-custom align-middle text-center" id="tablaCarritos">
                    <thead>
                        <tr>
                            <th><i class="bi bi-calendar3"></i> Fecha de Creación</th>
                            <th><i class="bi bi-person-circle"></i> Usuario</th>
                            <th><i class="bi bi-gear-fill"></i> Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <!-- Fecha -->
                                <td>
                                    <i class="bi bi-clock-history me-1 text-secondary"></i>
                                    @item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <!-- Usuario con icono y nombre -->
                                <td class="text-start">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <div class="me-2">
                                            <i class="bi bi-person-badge-fill fs-5 text-primary"></i>
                                        </div>
                                        <span class="fw-semibold">
                                            @($"{item.Usuario?.Nombre} {item.Usuario?.Apellido}")
                                        </span>
                                    </div>
                                </td>

                                <!-- Acciones -->
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.CarritoId"
                                       class="btn-icon btn-edit" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.CarritoId"
                                       class="btn-icon btn-details" title="Detalles">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.CarritoId"
                                       class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const input = document.getElementById("txtBuscar");
            const filas = document.querySelectorAll("#tablaCarritos tbody tr");

            input.addEventListener("keyup", function () {
                let texto = this.value.toLowerCase();

                filas.forEach(fila => {
                    let fecha = fila.children[0].innerText.toLowerCase();
                    let usuario = fila.children[1].innerText.toLowerCase();

                    if (fecha.includes(texto) || usuario.includes(texto)) {
                        fila.style.display = "";
                    } else {
                        fila.style.display = "none";
                    }
                });
            });
        });
    </script>
}