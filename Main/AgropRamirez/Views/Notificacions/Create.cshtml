@model AgropRamirez.Models.Notificacion

@{
    ViewData["Title"] = "Registrar Notificación";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Nueva Notificación</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Notificaciones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Crear</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-bell-fill"></i> Registrar Notificación
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row align-items-center">
                            <!-- Ícono lateral -->
                            <div class="col-md-4 text-center mb-4 mb-md-0">
                                <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center">
                                    <i class="bi bi-bell zoom-avatar text-primary"></i>
                                </div>
                            </div>

                            <!-- Formulario -->
                            <div class="col-md-8">
                                <!-- Usuario -->
                                <div class="mb-3">
                                    <label asp-for="UsuarioId" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                                        <select asp-for="UsuarioId" class="form-select" asp-items="ViewBag.UsuarioId"></select>
                                    </div>
                                    <span asp-validation-for="UsuarioId" class="text-danger"></span>
                                </div>

                                <!-- Título -->
                                <div class="mb-3">
                                    <label asp-for="Titulo" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                        <input asp-for="Titulo" class="form-control" placeholder="Ej. Recordatorio de pago" />
                                    </div>
                                    <span asp-validation-for="Titulo" class="text-danger"></span>
                                </div>

                                <!-- Mensaje -->
                                <div class="mb-3">
                                    <label asp-for="Mensaje" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-chat-left-dots"></i></span>
                                        <textarea asp-for="Mensaje" class="form-control" rows="3" placeholder="Escriba el contenido de la notificación..."></textarea>
                                    </div>
                                    <span asp-validation-for="Mensaje" class="text-danger"></span>
                                </div>

                                <!-- Fecha -->
                                <div class="mb-3">
                                    <label asp-for="Fecha" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-calendar-date"></i></span>
                                        <input asp-for="Fecha" class="form-control" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                    </div>
                                    <span asp-validation-for="Fecha" class="text-danger"></span>
                                </div>

                                <!-- Leído -->
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" asp-for="Leido" type="checkbox" />
                                    <label class="form-check-label fw-semibold" asp-for="Leido"></label>
                                </div>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between mt-4">
                            <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle"></i> Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
