@model IEnumerable<AgropRamirez.Models.Notificacion>

@{
    ViewData["Title"] = "Listado de Notificaciones";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Notificaciones</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Notificaciones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Listado</li>
            </ol>
        </nav>
    </div>
</div>

@{
    bool esAdmin = ViewBag.EsAdmin ?? false;
    bool soloPropias = ViewBag.SoloPropias ?? false;
}

<div class="container mb-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">
                    <i class="bi bi-bell-fill"></i> Lista de Notificaciones
                </h4>

                <div>
                    @if (esAdmin)
                    {
                        <a asp-action="Index" asp-route-soloPropias="@(soloPropias ? false : true)"
                           class="btn btn-outline-primary me-2">
                            <i class="bi bi-funnel"></i>
                            @(soloPropias ? "Ver todas" : "Ver solo mis notificaciones")
                        </a>
                    }

                   @*  @if (User.IsInRole("Administrador"))
                    { *@
                        <a asp-action="Create" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Nueva Notificación
                        </a>
                    @* } *@
                </div>
            </div>

            <!-- 🔍 FILTROS -->
            <div class="row g-3 bg-light p-3 rounded-3 mb-4 mt-2">

                <!-- Buscar -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-search"></i> Buscar
                    </label>
                    <input type="text" id="buscarNoti" class="form-control"
                           placeholder="Título, mensaje, usuario, fecha..." />
                </div>

                <!-- Estado -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-envelope-check"></i> Estado
                    </label>
                    <select id="filtroEstadoNoti" class="form-select">
                        <option value="">Todos</option>
                        <option value="leído">Leído</option>
                        <option value="no leído">No leído</option>
                    </select>
                </div>

                <!-- Desde -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar-event"></i> Desde
                    </label>
                    <input type="date" id="fechaDesde" class="form-control" />
                </div>

                <!-- Hasta -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar-check"></i> Hasta
                    </label>
                    <input type="date" id="fechaHasta" class="form-control" />
                </div>

                <!-- Solo para ADMIN: filtrar por usuario -->
              @*   @if ((bool)ViewBag.EsAdmin)
                {
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-person-fill"></i> Usuario
                        </label>
                        <input type="text" id="filtroUsuario" class="form-control"
                               placeholder="Nombre o apellido..." />
                    </div>
                } *@

                <!-- Botón limpiar -->
                <div class="col-md-1 d-flex align-items-end">
                    <button id="limpiarNotis" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>
            </div>

            <!-- Tabla -->
            <div class="table-responsive">
                <table class="table table-custom align-middle text-center" id="tablaNotificaciones">
                    <thead>
                        <tr>
                            <th><i class="bi bi-card-heading"></i> Título</th>
                            <th><i class="bi bi-chat-left-dots-fill"></i> Mensaje</th>
                            <th><i class="bi bi-calendar-date-fill"></i> Fecha</th>
                            <th><i class="bi bi-envelope-check-fill"></i> Estado</th>
                            <th><i class="bi bi-person-fill"></i> Usuario</th>
                            <th><i class="bi bi-gear-fill"></i> Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            // 🔴 Si no está leída → clase "no-leida" (rojo suave)
                            string rowClass = item.Leido ? "" : "bg-light-danger";

                            <tr class="@rowClass">
                                <td>@item.Titulo</td>
                                <td>@item.Mensaje</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>

                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-flex align-items-center justify-content-center">
                                        <input class="form-check-input toggle-leido" type="checkbox"
                                               data-id="@item.NotificacionId"
                                               @(item.Leido ? "checked" : "") />
                                        <label class="form-check-label ms-2">
                                            @if (item.Leido)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle"></i> Leído
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-envelope"></i> No leído
                                                </span>
                                            }
                                        </label>
                                    </div>
                                </td>

                                <td>@($"{item.Usuario?.Nombre} {item.Usuario?.Apellido}")</td>
                                <td>

                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.NotificacionId"
                                           class="btn-icon btn-edit" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                    }
                                    
                                    <a asp-action="Details" asp-route-id="@item.NotificacionId"
                                       class="btn-icon btn-details" title="Detalles">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.NotificacionId"
                                       class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $(".toggle-leido").change(function () {
                const id = $(this).data("id");
                const leido = $(this).is(":checked");

                $.ajax({
                    url: '/Notificacions/CambiarEstado',
                    type: 'POST',
                    data: { id: id, leido: leido },
                    success: function (res) {
                        if (res.success) {
                            // ✅ Actualizar el contador del navbar
                            const $contador = $("#notificacionesCount");
                            if (res.noLeidas > 0) {
                                $contador.text(res.noLeidas).show();
                            } else {
                                $contador.text("0").hide();
                            }

                            // ✅ Actualizar el texto visual en la tabla
                            const fila = $(`[data-id='${id}']`).closest('tr');
                            if (leido) {
                                fila.find('.badge')
                                    .removeClass('bg-danger')
                                    .addClass('bg-success')
                                    .html('<i class="bi bi-check-circle"></i> Leído');
                            } else {
                                fila.find('.badge')
                                    .removeClass('bg-success')
                                    .addClass('bg-danger')
                                    .html('<i class="bi bi-envelope"></i> No leído');
                            }
                        }
                    }
                });
            });
        });
    </script>

    @* filtros *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const txtBuscar = document.getElementById("buscarNoti");
            const filtroEstado = document.getElementById("filtroEstadoNoti");
            const fechaDesde = document.getElementById("fechaDesde");
            const fechaHasta = document.getElementById("fechaHasta");
            const filtroUsuario = document.getElementById("filtroUsuario");
            const limpiar = document.getElementById("limpiarNotis");

            const filas = document.querySelectorAll("#tablaNotificaciones tbody tr");

            function filtrarNotificaciones() {

                let texto = txtBuscar.value.toLowerCase();
                let estado = filtroEstado.value.toLowerCase();
                let desde = fechaDesde.value ? new Date(fechaDesde.value) : null;
                let hasta = fechaHasta.value ? new Date(fechaHasta.value) : null;
                let usuario = filtroUsuario ? filtroUsuario.value.toLowerCase() : "";

                filas.forEach(fila => {

                    let contenido = fila.innerText.toLowerCase();

                    // FECHA (tercera columna)
                    let fechaTexto = fila.children[2].innerText.trim();
                    let fecha = new Date(fechaTexto.split("/").reverse().join("-"));

                    // ESTADO: leído / no leído
                    let estadoFila = fila.children[3].innerText.toLowerCase();

                    let coincideTexto = contenido.includes(texto);
                    let coincideEstado = estado === "" || estadoFila.includes(estado);
                    let coincideUsuario = usuario === "" || contenido.includes(usuario);
                    let coincideDesde = !desde || fecha >= desde;
                    let coincideHasta = !hasta || fecha <= hasta;

                    if (coincideTexto && coincideEstado && coincideUsuario && coincideDesde && coincideHasta) {
                        fila.style.display = "";
                    } else {
                        fila.style.display = "none";
                    }
                });
            }

            // EVENTOS
            txtBuscar.addEventListener("keyup", filtrarNotificaciones);
            filtroEstado.addEventListener("change", filtrarNotificaciones);
            fechaDesde.addEventListener("change", filtrarNotificaciones);
            fechaHasta.addEventListener("change", filtrarNotificaciones);
            if (filtroUsuario) filtroUsuario.addEventListener("keyup", filtrarNotificaciones);

            limpiar.addEventListener("click", function () {
                txtBuscar.value = "";
                filtroEstado.value = "";
                fechaDesde.value = "";
                fechaHasta.value = "";
                if (filtroUsuario) filtroUsuario.value = "";
                filtrarNotificaciones();
            });
        });
    </script>
}