@model AgropRamirez.Models.PedidoDetalle

@{
    ViewData["Title"] = "Eliminar Detalle de Pedido";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Eliminar Detalle</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Detalles del Pedido</a></li>
                <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header-delete text-center py-3 bg-danger">
                    <h4 class="mb-0 text-white fw-bold">
                        <i class="bi bi-trash"></i> Confirmar Eliminación
                    </h4>
                </div>

                <!-- Cuerpo -->
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <!-- Avatar / Ícono --> 
                        <div class="col-md-4 text-center mb-4 mb-md-0"> 
                            <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center"> 
                                <i class="bi bi-cart-x-fill zoom-avatar-delete text-danger"></i> 
                            </div> 
                        </div>

                        <!-- Contenido principal -->
                        <div class="col-md-8">
                            <h5 class="text-danger fw-bold mb-3">
                                <i class="bi bi-exclamation-triangle-fill"></i> Eliminación de detalle
                            </h5>

                            <div class="text-secondary mb-3" style="font-size: 1rem;">
                                <p class="mb-2">
                                    <i class="bi bi-person-fill me-2 text-danger"></i>
                                    <strong>Cliente:</strong> @($"{Model.Pedido.Usuario?.Nombre} {Model.Pedido.Usuario?.Apellido}")
                                </p>
                                <p class="mb-0">
                                    <i class="bi bi-calendar3 me-2 text-danger"></i>
                                    <strong>Fecha del Pedido:</strong> @Model.Pedido.FechaPedido.ToString("dd/MM/yyyy")
                                </p>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <!-- Lista de productos -->
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-box-fill text-success"></i> Productos del Pedido
                    </h5>

                    <ul class="list-unstyled mb-0 ps-2">
                        @foreach (var detalle in Model.Pedido.PedidoDetalles)
                        {
                            <li class="mb-2">
                                <i class="bi bi-dot text-success"></i>
                                <strong>@detalle.Producto.Nombre</strong><br />
                                <span class="text-muted ps-3" style="font-size: 0.95rem;">
                                    Cant: @detalle.Cantidad<br />
                                    Precio Unitario: S/ @detalle.PrecioUnitario.ToString("0.00")<br />
                                    Subtotal: <strong>S/ @((detalle.Cantidad * detalle.PrecioUnitario).ToString("0.00"))</strong>
                                </span>
                            </li>
                        }
                    </ul>

                    <!-- Total general -->
                    <div class="text-end fs-6 fw-bold mt-3">
                        <i class="bi bi-cash-coin text-success"></i> Total:
                        S/ @Model.Pedido.PedidoDetalles.Sum(p => p.Cantidad * p.PrecioUnitario).ToString("0.00")
                    </div>

                    <!-- Advertencia final -->
                    <div class="alert alert-warning mt-4 mb-0 text-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        ¿Estás seguro de que deseas eliminar este detalle?<br />
                        <span class="fw-semibold">Esta acción eliminará el detalle de pedido seleccionado y no se podrá deshacer.</span>
                    </div>

                    <!-- Formulario -->
                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="PedidoDetalleId" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash-fill"></i> Eliminar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div></div>
