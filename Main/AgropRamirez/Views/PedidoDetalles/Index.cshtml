@model IEnumerable<AgropRamirez.Models.PedidoDetalle>

@{
    ViewData["Title"] = "Detalles de Pedido";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Detalles de Pedido</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a href="#">Inicio</a></li>
                <li class="breadcrumb-item active" aria-current="page">Detalles de Pedido</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container mb-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">
            <!-- Header con título y botón -->
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
                <h4 class="mb-0"><i class="bi bi-receipt-cutoff"></i> Lista de Detalles de Pedido</h4>
               @*  <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-circle-fill"></i> Nuevo Detalle
                </a> *@
                <a asp-controller="Carritoes" asp-action="Create" class="btn btn-success">
                    <i class="bi bi-cart-plus-fill"></i> Nuevo Detalle
                </a>
            </div>

            <!-- 🔍 FILTROS -->
            <div class="row g-3 bg-light p-3 rounded-3 mb-4 mt-3">

                <!-- Buscar texto -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-search"></i> Buscar
                    </label>
                    <input type="text" id="buscarPedidos" class="form-control"
                           placeholder="Cliente, producto, total, fecha, estado..." />
                </div>

                <!-- Filtro por estado -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-ui-checks"></i> Estado de pago
                    </label>
                    <select id="filtroEstado" class="form-select">
                        <option value="">Todos</option>
                        <option value="pagado">Pagado</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="anulado">Anulado</option>
                        <option value="sin pago">Sin pago</option>
                    </select>
                </div>

                <!-- Fecha desde -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar-event"></i> Desde
                    </label>
                    <input type="date" id="fechaDesde" class="form-control" />
                </div>

                <!-- Fecha hasta -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar-check"></i> Hasta
                    </label>
                    <input type="date" id="fechaHasta" class="form-control" />
                </div>

                <!-- Botón limpiar -->
                <div class="col-md-1 d-flex align-items-end">
                    <button id="limpiarFiltros" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>
            </div>

            <!-- Tabla -->
            <div class="table-responsive">
                <table class="table table-custom align-middle text-center" id="tablaPedidos">
                    <thead>
                        <tr>
                            <th><i class="bi bi-person-circle"></i> Cliente</th>
                            <th><i class="bi bi-calendar3"></i> Fecha Pedido</th>
                            <th><i class="bi bi-box-seam"></i> Producto(s)</th>
                            <th><i class="bi bi-basket"></i> Cantidad Total</th>
                            <th><i class="bi bi-cash-coin"></i> Total Pedido</th>
                            <th><i class="bi bi-cash-coin"></i> Estado de Pago</th>
                             @if (User.IsInRole("Administrador"))
                                {
                                    <th><i class="bi bi-gear-fill"></i> Acciones</th>
                                }
                        </tr>
                    </thead>
                    <tbody>
                        @* Agrupamos por pedido, para que un solo pedido (con varios productos) se muestre en una fila *@
                        @{
                            var pedidosAgrupados = Model
                            .GroupBy(d => d.PedidoId)
                            .Select(grupo => new
                            {
                                Pedido = grupo.First().Pedido,
                                Detalles = grupo.Select(g => new
                                {
                                    Producto = g.Producto.Nombre,
                                    Cantidad = g.Cantidad,
                                    Precio = g.PrecioUnitario
                                }).ToList(),
                                CantidadTotal = grupo.Sum(g => g.Cantidad),
                                Total = grupo.Sum(g => g.Cantidad * g.PrecioUnitario),
                                PedidoDetalleId = grupo.First().PedidoDetalleId
                            });
                        }

                        @foreach (var item in pedidosAgrupados)
                        {
                            <tr>
                                <td>@($"{item.Pedido.Usuario?.Nombre} {item.Pedido.Usuario?.Apellido}")</td>
                                <td>@item.Pedido.FechaPedido.ToString("dd/MM/yyyy")</td>

                                <!-- Productos en lista -->
                                <td class="text-start">
                                    <ul class="list-unstyled mb-0 productos-lista">
                                        @foreach (var detalle in item.Detalles)
                                        {
                                            <li class="mb-3">
                                                <div>
                                                    <i class="bi bi-dot text-success"></i>
                                                    <strong>@detalle.Producto:</strong>
                                                </div>
                                                <div class="ps-4 text-muted">
                                                    Cant. @detalle.Cantidad<br />
                                                    S/ @detalle.Precio.ToString("0.00")
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                </td>

                                <td class="text-center">@item.CantidadTotal</td>
                                <td>S/ @item.Total.ToString("0.00")</td>


                                <td>
                                    @{
                                        // Toma el último pago del pedido (por si hay más de uno)
                                        var pago = item.Pedido.Pagos.OrderByDescending(p => p.PagoId).FirstOrDefault();
                                        string estado = pago?.Estado ?? "Pendiente";
                                    }

                                    @if (estado == "Completado" || estado == "Pagado")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Pagado</span>
                                    }
                                    else if (estado == "Pendiente")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Pendiente</span>
                                    }
                                    else if (estado == "Anulado")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle-fill"></i> Fallido</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Sin Pago</span>
                                    }
                                </td>

                                @if (User.IsInRole("Administrador"))
                                {
                                    <td class="text-center">
                                        @* <a asp-action="Edit" asp-route-id="@item.PedidoDetalleId"
                                        class="btn-icon btn-edit" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a> *@
                                        <a asp-action="Details" asp-route-id="@item.PedidoDetalleId"
                                        class="btn-icon btn-details" title="Detalles">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.PedidoDetalleId"
                                        class="btn-icon btn-delete" title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const txtBusqueda = document.getElementById("buscarPedidos");
            const filtroEstado = document.getElementById("filtroEstado");
            const fechaDesde = document.getElementById("fechaDesde");
            const fechaHasta = document.getElementById("fechaHasta");
            const limpiarBtn = document.getElementById("limpiarFiltros");

            const filas = document.querySelectorAll("#tablaPedidos tbody tr");

            function filtrar() {
                let texto = txtBusqueda.value.toLowerCase();
                let estado = filtroEstado.value.toLowerCase();
                let desde = fechaDesde.value ? new Date(fechaDesde.value) : null;
                let hasta = fechaHasta.value ? new Date(fechaHasta.value) : null;

                filas.forEach(fila => {

                    let contenido = fila.innerText.toLowerCase();

                    // 📅 Fecha (segunda columna)
                    let fechaTexto = fila.children[1].innerText.trim();
                    let fechaPedido = new Date(fechaTexto.split("/").reverse().join("-"));

                    let coincideTexto = contenido.includes(texto);
                    let coincideEstado = estado === "" || contenido.includes(estado);
                    let coincideDesde = !desde || fechaPedido >= desde;
                    let coincideHasta = !hasta || fechaPedido <= hasta;

                    if (coincideTexto && coincideEstado && coincideDesde && coincideHasta) {
                        fila.style.display = "";
                    } else {
                        fila.style.display = "none";
                    }
                });
            }

            // Eventos de filtrado
            txtBusqueda.addEventListener("keyup", filtrar);
            filtroEstado.addEventListener("change", filtrar);
            fechaDesde.addEventListener("change", filtrar);
            fechaHasta.addEventListener("change", filtrar);

            // Botón limpiar filtros
            limpiarBtn.addEventListener("click", () => {
                txtBusqueda.value = "";
                filtroEstado.value = "";
                fechaDesde.value = "";
                fechaHasta.value = "";
                filtrar();
            });

        });
    </script>
}
