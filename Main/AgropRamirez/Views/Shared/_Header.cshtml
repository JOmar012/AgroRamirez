@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

@* Nombre en el navbar *@
@{
    var nombreCompleto = User.Identity?.Name ?? "";
    var soloNombre = string.Join(" ", nombreCompleto.Split(" ").Take(2));// esto te da "Juan" de "Juan Pérez"

    // Para ver perfil
    var usuarioId = User.FindFirst("UsuarioId")?.Value;
}



@{
    // Helper para marcar el link activo
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "");
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "");
    Func<string, string, string> active = (ctrl, act) =>
        string.Equals(currentController, ctrl, StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, act, StringComparison.OrdinalIgnoreCase)
        ? "active" : "";
}

<!-- Topbar Start -->
<div class="container-fluid bg-dark text-light px-0 py-2">
    <div class="row gx-0 d-none d-lg-flex">

        <!-- LEFT SIDE -->
        <div class="col-lg-7 px-5 text-start">
            <div class="h-100 d-inline-flex align-items-center me-4">
                <i class="fa fa-phone-alt me-2"></i>
                <span> + 51 976811514</span>
            </div>

            <div class="h-100 d-inline-flex align-items-center">
                <i class="far fa-envelope me-2"></i>
                <span>serviciosagropecuariosramirez@hotmail.com</span>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-lg-5 px-5 text-end">
            <div class="h-100 d-inline-flex align-items-center mx-n2">

                <!-- Redes sociales -->
                <span class="me-2">Síguenos:</span>
                <a class="btn btn-link text-light px-2" href="#"><i class="fab fa-facebook-f"></i></a>
                <a class="btn btn-link text-light px-2" href="#"><i class="fab fa-twitter"></i></a>
                <a class="btn btn-link text-light px-2" href="#"><i class="fab fa-linkedin-in"></i></a>
                <a class="btn btn-link text-light px-2" href="#"><i class="fab fa-instagram"></i></a>

                <!-- 🔧 BOTÓN MODO DALTÓNICO -->
                <div class="modo-daltonico-switch ms-3">
                    <label class="switch">
                        <input type="checkbox" id="toggleDaltonico">
                        <span class="slider round"></span>
                    </label>
                    <span class="ms-2" id="textoDaltonico">🧩 Modo daltónico</span>
                </div>

            </div>
        </div>
    </div>
</div>
<!-- Topbar End -->


<!-- Navbar Start -->
<nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top p-0">
    <a asp-controller="Home" asp-action="Index" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
        <img src="~/img/LOGO1.png" alt="Logo S.A.R" style="height:60px; width:auto; margin-right:10px;" />
        <div class="d-flex flex-column" style="font-style: italic; line-height:1.1;">
            <span class="fw-bold fs-3">S.A.R</span>
            <span style="font-size: 0.6rem;">Servicios Agropecuarios</span>
            <span style="font-size: 0.6rem;">Ramírez EIRL</span>
        </div>
    </a>

    <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarCollapse">
        <ul class="navbar-nav ms-auto p-4 p-lg-0">

            <!-- Secciones principales -->
            <li class="nav-item">
                <a asp-controller="Home" asp-action="Index" class="nav-link @active("Home", "Index")">Inicio</a>
            </li>
            <li class="nav-item">
                <a asp-controller="Home" asp-action="Nosotros" class="nav-link @active("Home", "Nosotros")">Nosotros</a>
            </li>

            <!-- Servicios -->
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle @active("Home", "Service")" href="#" id="navbarDropdownServicios"
                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-gear-fill"></i> Servicios
                </a>
                <ul class="dropdown-menu shadow-sm rounded-3" aria-labelledby="navbarDropdownServicios">

                    <!-- Productos -->
                    <li>
                        <a asp-controller="Productoes" asp-action="Index" class="dropdown-item d-flex align-items-center">
                            <i class="bi bi-box-seam me-2 text-primary fs-5"></i>
                            <span>Productos</span>
                        </a>
                    </li>

                    <!-- Promociones -->
                    <li>
                        <a asp-controller="Promocions" asp-action="Index" class="dropdown-item d-flex align-items-center">
                            <i class="bi bi-gift-fill me-2 text-danger fs-5"></i>
                            <span>Promociones</span>
                        </a>
                    </li>

                    <li><hr class="dropdown-divider"></li>

                    <!-- Cotizaciones -->
                    <li>
                        <a asp-controller="Cotizacions" asp-action="Index" class="dropdown-item d-flex align-items-center">
                            <i class="bi bi-file-earmark-text-fill me-2 text-success fs-5"></i>
                            <span>Cotizaciones</span>
                        </a>
                    </li>

                </ul>
            </li>

            <li class="nav-item">
                <a asp-controller="Home" asp-action="Contacto" class="nav-link @active("Home", "Contacto")">Contacto</a>
            </li>

            <!-- GESTIONAR -->
            @if (User.Identity.IsAuthenticated && User.IsInRole("Administrador"))
            {
                <li class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" id="dropdownGestionar" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-briefcase"></i> Gestionar
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownGestionar">
                        <li><a asp-controller="Usuarios" asp-action="Index" class="dropdown-item">Usuarios</a></li>
                        <li><a asp-controller="Categorias" asp-action="Index" class="dropdown-item">Categorías</a></li>
                       @*  <li><a asp-controller="Productoes" asp-action="Index" class="dropdown-item">Productos</a></li>
                        <li><a asp-controller="Promocions" asp-action="Index" class="dropdown-item">Promociones</a></li> *@
                        <li><a asp-controller="Carritoes" asp-action="Index" class="dropdown-item">Carrito Compras</a></li>
                        <li><a asp-controller="PedidoDetalles" asp-action="Index" class="dropdown-item">Pedidos</a></li>
                        <li><a asp-controller="Pagoes" asp-action="Index" class="dropdown-item">Pagos</a></li>
                        @* <li><a asp-controller="Notificacions" asp-action="Index" class="dropdown-item">Notificaciones</a></li> *@
                        @* <li><a asp-controller="Cotizacions" asp-action="Index" class="dropdown-item">Cotizaciones</a></li> *@
                       @*  <li><a asp-controller="CotizacionDetalles" asp-action="Index" class="dropdown-item">Detalles Cotización</a></li> *@
                    </ul>
                </li>
            }

            <!-- 🔔 Notificaciones -->
            @if (User.Identity.IsAuthenticated)
            {
                @* <li class="nav-item dropdown position-relative" id="navbarNotificacionesContainer">
                    <a class="nav-link position-relative" href="#" id="notifDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-bell-fill fs-5"></i>
                    </a>

                    <!-- Tu partial original (mantiene funcionalidad del contador) -->
                    <partial name="_NotificacionesNavbar" model="new List<AgropRamirez.Models.Notificacion>()" />
                </li> *@

                @* notificaciones *@

                <li class="nav-item dropdown position-relative" id="navbarNotificacionesContainer">
                    <!-- Aquí se cargará el partial por AJAX -->
                </li>


                <!-- 🛒 Carrito -->
                <li class="nav-item position-relative">
                    <a class="nav-link position-relative" asp-controller="Carritoes" asp-action="MiCarrito">
                        <i class="bi bi-cart4 fs-5"></i>
                        <span id="cartCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark" style="display:none;">
                            0
                        </span>
                    </a>
                </li>

            }

            

            <!-- 👤 Cuenta -->
            @if (User.Identity.IsAuthenticated)
            {
   

                <li class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle text-capitalize" id="dropdownCuenta"
                       role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle"></i> @soloNombre
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="dropdownCuenta">

                        <!-- Ver Perfil -->
                        <li>
                            <a asp-controller="Usuarios" asp-action="Details" asp-route-id="@usuarioId"
                               class="dropdown-item">
                                <i class="bi bi-person-badge me-2 text-primary"></i> Ver perfil
                            </a>
                        </li>

                        <li><hr class="dropdown-divider" /></li>

                        <!-- Notificaciones -->
                        <li>
                            <a asp-controller="Notificacions" asp-action="Index"
                               class="dropdown-item">
                                <i class="bi bi-bell-fill me-2 text-info"></i> Notificaciones
                            </a>
                        </li>

                        <li><hr class="dropdown-divider" /></li>

                        <!-- Cerrar sesión -->
                        <li>
                            <a asp-controller="Cuenta" asp-action="Logout" class="dropdown-item text-danger fw-semibold">
                                <i class="bi bi-box-arrow-right me-2"></i> Cerrar sesión
                            </a>
                        </li>
                    </ul>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Cuenta" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right"></i> Iniciar sesión
                    </a>
                </li>
            }

        </ul>
    </div>
</nav>
<!-- Navbar End -->

