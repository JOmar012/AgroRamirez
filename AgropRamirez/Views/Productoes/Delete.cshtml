@model AgropRamirez.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Eliminar Producto</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Productos</a></li>
                <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Encabezado -->
                <div class="card-header custom-header-delete text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-trash-fill"></i> Eliminar Producto
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="row align-items-stretch">
                        <!-- Imagen -->
                        <div class="col-md-4 text-center mb-4 mb-md-0 d-flex align-items-stretch">
                            <img src="@(string.IsNullOrEmpty(Model.Imagen) ? Url.Content("~/img/no-image.png") : Model.Imagen)"
                                 alt="Imagen del producto"
                                 class="img-fluid rounded-3 shadow-sm zoom-image w-100"
                                 style="object-fit: cover; height: 100%;" />
                        </div>

                        <!-- Información -->
                        <div class="col-md-8 d-flex flex-column justify-content-between">
                            <div>
                                <h4 class="fw-bold text-dark mb-2">@Model.Nombre</h4>
                                <p class="text-muted mb-4">@Model.Descripcion</p>

                                <div class="info-section">
                                    <p class="mb-2">
                                        <i class="bi bi-currency-dollar me-2 text-danger"></i>
                                        <strong>Precio Unitario:</strong> S/ @Model.Precio
                                    </p>
                                    <p class="mb-2">
                                        <i class="bi bi-cart4 me-2 text-danger"></i>
                                        <strong>Precio por Mayor:</strong>
                                        @(Model.PrecioPorMayor.HasValue ? $"S/ {Model.PrecioPorMayor}" : "-")
                                    </p>
                                    <p class="mb-2">
                                        <i class="bi bi-123 me-2 text-danger"></i>
                                        <strong>Umbral Mayorista:</strong>
                                        @(Model.UmbralMayorista.HasValue? Model.UmbralMayorista + " unidades" : "-")
                                    </p>
                                    <p class="mb-2">
                                        <i class="bi bi-box-seam me-2 text-danger"></i>
                                        <strong>Stock:</strong> @Model.Stock
                                    </p>
                                    <p class="mb-0">
                                        <i class="bi bi-tags me-2 text-danger"></i>
                                        <strong>Categoría:</strong> @Model.Categoria?.Nombre
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Advertencia -->
                    <div class="alert alert-danger d-flex align-items-center mt-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div>
                            ¿Estás seguro de que deseas eliminar este producto? <br />
                            <strong>Esta acción no se puede deshacer.</strong>
                        </div>
                    </div>

                    <!-- Botones -->
                    <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-3 mt-3">
                        <input type="hidden" asp-for="ProductoId" />
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash-fill"></i> Eliminar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-arrow-left-circle"></i> Cancelar
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>