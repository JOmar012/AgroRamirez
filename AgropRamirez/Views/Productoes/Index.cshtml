@* @model IEnumerable<AgropRamirez.Models.Producto> *@
@model AgropRamirez.ViewModels.ProductosIndexViewModel

@{
    ViewData["Title"] = "Productos";
}

<!-- Page Header Productos -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s"
     style="background: linear-gradient(rgba(0,0,0,.6), rgba(0,0,0,.6)), url('/img/Campos.jpg') center center/cover no-repeat;">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">
            <i class="bi bi-box-seam"></i> Catálogo de Productos
        </h1>
        <p class="text-white-50 fs-5 animated fadeIn">
            <i class="bi bi-bag-check"></i> Encuentra lo que necesitas al mejor precio
        </p>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item active" aria-current="page">Productos</li>
            </ol>
        </nav>
    </div>
</div>


<!-- Header fuera del card -->
<div class="container mb-3">
    <div class="d-flex justify-content-between align-items-center">
        <!-- Título centrado -->
        <h2 class="mb-0 d-flex align-items-center"
            style="
                position: absolute;
                left: 50%;
                transform: translateX(-50%);
            ">
            <i class="bi bi-box-seam me-2"></i> Lista de Productos
        </h2>

        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Create" class="btn btn-success d-flex align-items-center">
            <i class="bi bi-plus-circle me-1"></i> Nuevo Producto
            </a>
        }
        
    </div>
</div>

<div class="container mb-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">

            

           <!-- 🔎 Buscador por categoría y nombre -->
            <form method="get" class="mb-4">
                <div class="row g-3 bg-light p-3 rounded-3 border">

            <!-- Select Categoría -->
            <div class="col-md-4">
                <label class="form-label fw-semibold">
                    <i class="bi bi-filter"></i> Filtrar por categoría
                </label>
                <select name="categoriaId" class="form-select" id="categoriaSelect">
                    <option value="">Todas las categorías</option>
                    @foreach (var cat in Model.Categorias)
                    {
                                <option value="@cat.CategoriaId"
                                        selected="@(Model.CategoriaId == cat.CategoriaId)">
                                    @cat.Nombre
                                </option>
                    }
                </select>
            </div>

                    

            <!-- Búsqueda por nombre -->
            <div class="col-md-5">
                <label class="form-label fw-semibold">
                    <i class="bi bi-search"></i> Buscar por nombre
                </label>
                <input type="text" name="busqueda"
                       value="@Model.Busqueda"
                       class="form-control"
                       placeholder="Ej: Semilla, fertilizante, alimento..." />
            </div>

            <!-- Botones -->
            <div class="col-md-3 d-flex gap-2 align-items-end">
                <button class="btn btn-primary flex-fill" type="submit">
                    <i class="bi bi-search"></i> Buscar
                </button>

                <a href="@Url.Action("Index")" class="btn btn-outline-secondary flex-fill">
                    Limpiar
                </a>
            </div>

        </div>
</form>

            <!-- GRID: 4 columnas × 2 filas = 8 productos -->
            <div class="row justify-content-center g-4 mt-3">
                @foreach (var item in Model.Productos)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="card h-100 shadow-lg border-0 rounded-3 product-card">

                            <!-- Imagen -->
                            <a asp-action="Details" asp-route-id="@item.ProductoId" class="text-decoration-none text-dark">
                                <div class="position-relative bg-light" style="height:200px; overflow:hidden;">
                                    <img src="@item.Imagen" alt="@item.Nombre"
                                         class="w-100 h-100"
                                         style="object-fit:cover;" />

                                    <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">
                                        @item.Categoria?.Nombre
                                    </span>
                                </div>
                            </a>

                            <!-- Body -->
                            <div class="card-body d-flex flex-column text-start flex-grow-1">
                                <h5 class="card-title fw-bold text-center text-dark" style="font-size:1.1rem;">
                                    @item.Nombre
                                </h5>

                                <p class="card-text text-muted flex-grow-1 mb-2" style="font-size:0.9rem; min-height:40px;">
                                    @(item.Descripcion?.Length > 60
                                                                    ? item.Descripcion.Substring(0, 60) + "..."
                                                                    : item.Descripcion)
                            </p>

                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <div>
                                        <p class="fw-bold mb-1 text-success">S/ @item.Precio</p>
                                        <small class="text-danger fw-semibold">Stock: @item.Stock</small>
                                    </div>

                                    @* Botón dependiendo del rol *@
                                @if (!User.Identity.IsAuthenticated)
                                    {
                                        <button type="button"
                                                class="btn btn-warning text-dark fw-bold add-to-cart"
                                                data-id="@item.ProductoId"
                                                data-cantidad="1"
                                                data-authenticated="False"
                                                data-admin="False">
                                            <i class="bi bi-box-arrow-in-right"></i> Comprar
                                        </button>
                                    }
                                    else if (User.IsInRole("Administrador"))
                                    {
                                        <button type="button"
                                                class="btn btn-warning text-dark fw-bold add-to-cart"
                                                data-id="@item.ProductoId"
                                                data-cantidad="1"
                                                data-authenticated="True"
                                                data-admin="True">
                                            <i class="bi bi-gear-fill"></i> Crear carrito
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-warning text-dark fw-bold add-to-cart"
                                                data-id="@item.ProductoId"
                                                data-cantidad="1"
                                                data-authenticated="True"
                                                data-admin="False">
                                            <i class="bi bi-cart-plus"></i> Agregar
                                        </button>
                                    }
                                </div>
                            </div>

                            <!-- Footer administrador -->
                            @if (User.IsInRole("Administrador"))
                            {
                                <div class="card-footer bg-white border-0 d-flex justify-content-center gap-2 mt-auto">
                                    <a asp-action="Details" asp-route-id="@item.ProductoId" class="btn btn-outline-info btn-sm"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.ProductoId" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.ProductoId" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash-fill"></i></a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- PAGINACIÓN -->
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">

                    <!-- Botón Anterior -->
                    <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { pagina = Model.PaginaActual - 1, categoriaId = Model.CategoriaId, busqueda = Model.Busqueda })">
                            <i class="bi bi-chevron-left"></i> Anterior
                        </a>
                    </li>

                    <!-- Números -->
                    @for (int i = 1; i <= Model.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pagina = i, categoriaId = Model.CategoriaId, busqueda = Model.Busqueda })">
                                @i
                            </a>
                        </li>
                    }

                    <!-- Botón Siguiente -->
                    <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { pagina = Model.PaginaActual + 1, categoriaId = Model.CategoriaId, busqueda = Model.Busqueda })">
                            Siguiente <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>

                </ul>
            </nav>

        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        // ✅ Hacer que toda la tarjeta sea clickeable (excepto los botones y enlaces internos)
        document.addEventListener("DOMContentLoaded", () => {
            const cards = document.querySelectorAll(".product-card");

            cards.forEach(card => {
                card.addEventListener("click", function (e) {
                    // Si el clic fue en un botón, un link o un icono dentro de un botón, no hacer nada
                    if (e.target.closest("button") || e.target.closest("a") || e.target.closest("i")) return;

                    // Redirigir al Details del producto
                    const link = this.querySelector("a[href*='Details']");
                    if (link) {
                        window.location.href = link.href;
                    }
                });

                // 💅 Opcional: cursor de "mano" para dejar claro que es clickeable
                card.style.cursor = "pointer";
            });
        });
    </script>

   @*  //busqueda instantanea *@

    <script>
        // Auto-Búsqueda por categoría
        document.getElementById("categoriaSelect").addEventListener("change", function () {
            this.form.submit();
        });

        // Auto-búsqueda por nombre (busca en la BD)
        let delayTimer;
        const input = document.querySelector("input[name='busqueda']");

        input.addEventListener("keyup", function () {
            clearTimeout(delayTimer);
            delayTimer = setTimeout(() => {
                this.form.submit(); // 🔥 Se envía al servidor (controlador)
            }, 400); // espera 0.4s para no recargar demasiado
        });
    </script>
    
}
