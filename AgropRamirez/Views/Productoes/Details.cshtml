@model AgropRamirez.Models.Producto

@{
    ViewData["Title"] = "Detalles del Producto";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Detalles del Producto</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Productos</a></li>
                <li class="breadcrumb-item active" aria-current="page">Detalles</li>
            </ol>
        </nav>
    </div>
</div>
<div class="container my-4 detalles-promocion">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header-details text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-box-seam"></i> Detalles del Producto
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="row align-items-center">

                        <!-- Imagen -->
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="zoom-image">
                                <img src="@Model.Imagen"
                                     alt="Imagen del producto"
                                     class="img-fluid rounded-3 shadow-sm"
                                     style="width:100%; height:100%; object-fit:cover;" />
                            </div>
                        </div>

                        <!-- Información -->
                        <div class="col-md-8">
                            <h3 class="fw-bold text-dark mb-2">@Model.Nombre</h3>
                            <p class="text-muted mb-4">@Model.Descripcion</p>

                            <div class="fs-5">
                                <p><i class="bi bi-currency-dollar me-2 text-info"></i><strong>Precio Unitario:</strong> S/ @Model.Precio</p>
                                <p><i class="bi bi-cart4 me-2 text-info"></i><strong>Precio por Mayor:</strong> @(Model.PrecioPorMayor.HasValue ? $"S/ {Model.PrecioPorMayor}" : "-")</p>
                                <p><i class="bi bi-123 me-2 text-info"></i><strong>Umbral Mayorista:</strong> @(Model.UmbralMayorista.HasValue? Model.UmbralMayorista + " unidades" : "-")</p>
                                <p><i class="bi bi-box-seam me-2 text-info"></i><strong>Stock:</strong> @Model.Stock</p>
                                <p><i class="bi bi-tags me-2 text-info"></i><strong>Categoría:</strong> @Model.Categoria?.Nombre</p>
                            </div>
                        </div>
                    </div>

                    <!-- Botones -->
                    <div class="mt-4 d-flex justify-content-center gap-3">
                        @if (User.IsInRole("Administrador"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.ProductoId" class="btn btn-warning text-white px-4">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-arrow-left-circle"></i> Volver
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>