@* @model AgropRamirez.Models.Cotizacion *@
@model AgropRamirez.ViewModels.CotizacionCreateViewModel

@* //Saber si el usuario esta logueado o no *@
@using Microsoft.AspNetCore.Identity
@* @inject SignInManager<Usuario> SignInManager *@
@{
    bool isLogged = User.Identity.IsAuthenticated;
}


@{
    ViewData["Title"] = "Registrar Cotización";
    var productos = ViewBag.Productos as List<dynamic>;
    bool esAdmin = ViewBag.EsAdmin;
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Nueva Cotización</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Cotizaciones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Crear</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0"><i class="bi bi-file-earmark-text"></i> Registrar Cotización</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" id="formCotizacion">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Cliente -->
                        @if (esAdmin)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Cliente</label>
                                <select asp-for="Cotizacion.UsuarioId" class="form-select">
                                    <option value="">-- Seleccione un cliente --</option>
                                    @foreach (var u in ViewBag.Usuarios)
                                    {
                                        <option value="@u.UsuarioId">@u.NombreCompleto</option>
                                    }
                                </select>
                                <span asp-validation-for="Cotizacion.UsuarioId" class="text-danger"></span>
                            </div>
                        }

                        <!-- Fechas -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Vigencia</label>
                            <div class="alert alert-info mb-0">
                                <i class="bi bi-calendar-check"></i>
                                <strong>Desde:</strong> @Model.Cotizacion.FechaCotizacion.ToString("dd/MM/yyyy")<br />
                                <strong>Hasta:</strong> @Model.Cotizacion.ValidoHasta?.ToString("dd/MM/yyyy")<br />
                                <span class="text-muted">(Válido por 5 días desde la fecha actual)</span>
                            </div>

                            <!-- Campos ocultos para enviar al servidor -->
                            <input type="hidden" asp-for="Cotizacion.FechaCotizacion" />
                            <input type="hidden" asp-for="Cotizacion.ValidoHasta" />
                        </div>

                        <!-- Tabla de productos -->
                        <h5 class="mt-4 fw-bold text-primary">Productos</h5>
                        <table class="table table-bordered" id="tablaProductos">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th>Precio (S/)</th>
                                    <th>Cantidad</th>
                                    <th>Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>

                        <button type="button" class="btn btn-success mb-3" id="agregarProducto">
                            <i class="bi bi-plus-circle"></i> Agregar producto
                        </button>

                        <!-- Total -->
                        <div class="mb-3 text-end">
                            <h5>Total: <span id="total" class="fw-bold text-success">S/ 0.00</span></h5>
                        </div>

                        <!-- Estado (solo admin) -->
                        @if (esAdmin)
                        {
                            <div class="mb-3">
                                <label asp-for="Cotizacion.Estado" class="form-label fw-bold"></label>
                                <select asp-for="Cotizacion.Estado" class="form-select">
                                    <option value="Pendiente">Pendiente</option>
                                    <option value="Aceptada">Aceptada</option>
                                    <option value="Rechazada">Rechazada</option>
                                    <option value="Vencida">Vencida</option>
                                </select>
                            </div>
                        }

                        <!-- Botones -->
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left-circle"></i> Volver
                            </a>

                            @if (isLogged)
                            {
                                <!-- Usuario logueado: guarda en BD -->
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-circle"></i> Guardar Cotización
                                </button>
                            }
                            else
                            {
                                <!-- Usuario no logueado: genera PDF temporal -->
                                <button type="button" id="btnDescargarPdf" class="btn btn-outline-primary">
                                    <i class="bi bi-file-earmark-pdf"></i> Descargar Cotización
                                </button>
                            }
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(function () {
            const productos = @Html.Raw(ViewBag.ProductosJson ?? "[]");
            const tbody = $("#tablaProductos tbody");

            // 🔍 Detección de formato
            const usarCamel = productos.length && productos[0].productoId !== undefined;

            $("#agregarProducto").on("click", function () {
                if (!productos.length) {
                    Swal.fire({
                        icon: "warning",
                        title: "No hay productos disponibles",
                        toast: true,
                        position: "top-end",
                        timer: 2000,
                        showConfirmButton: false
                    });
                    return;
                }

                const p = productos[0];
                const get = k => usarCamel ? p[k.charAt(0).toLowerCase() + k.slice(1)] : p[k];

                const row = `
                    <tr>
                        <td>
                            <select class="form-select producto">
                                ${productos.map(prod => {
                                    const getP = k => usarCamel ? prod[k.charAt(0).toLowerCase() + k.slice(1)] : prod[k];
                                    return `<option value="${getP('ProductoId')}"
                                                data-precio="${getP('Precio')}"
                                                data-preciopormayor="${getP('PrecioPorMayor') || 0}"
                                                data-umbral="${getP('UmbralMayorista') || 0}"
                                                data-stock="${getP('Stock')}">
                                            ${getP('Nombre')}
                                        </option>`;
                                }).join("")}
                            </select>
                        </td>
                        <td><input type="number" class="form-control precio" value="${get('Precio').toFixed(2)}" readonly></td>
                        <td><input type="number" class="form-control cantidad" value="1" min="1" max="${get('Stock')}">
                            <div class="text-muted small">Stock: ${get('Stock')}</div>
                        </td>
                        <td class="subtotal">S/ ${get('Precio').toFixed(2)}</td>
                        <td><button type="button" class="btn btn-danger btn-sm eliminar"><i class="bi bi-trash"></i></button></td>
                    </tr>`;
                tbody.append(row);
                actualizarTotal();
            });

            // 🟡 Cambiar producto
            tbody.on("change", ".producto", function () {
                const row = $(this).closest("tr");
                const opt = $(this).find(":selected");
                const precio = parseFloat(opt.data("precio")) || 0;
                const stock = parseInt(opt.data("stock")) || 0;
                row.find(".precio").val(precio.toFixed(2));
                row.find(".cantidad").val(1).attr("max", stock);
                row.find(".subtotal").text(`S/ ${precio.toFixed(2)}`);
                actualizarTotal();
            });

            // 🟣 Cambiar cantidad
            tbody.on("input", ".cantidad", function () {
                const row = $(this).closest("tr");
                const opt = row.find(".producto option:selected");
                const cantidad = parseInt($(this).val()) || 1;
                const stock = parseInt(opt.data("stock")) || 0;

                if (cantidad > stock) {
                    Swal.fire({
                        icon: "warning",
                        title: "Stock insuficiente",
                        text: `Solo hay ${stock} unidades disponibles`,
                        toast: true,
                        position: "top-end",
                        timer: 2500,
                        showConfirmButton: false
                    });
                    $(this).val(stock);
                }

                aplicarPrecioMayorista(row, cantidad);
                actualizarSubtotal(row);
            });

            // 🔴 Eliminar fila
            tbody.on("click", ".eliminar", function () {
                $(this).closest("tr").remove();
                actualizarTotal();
            });

            // 💡 Lógica de precio mayorista
            function aplicarPrecioMayorista(row, cantidad) {
                const opt = row.find(".producto option:selected");
                const precioNormal = parseFloat(opt.data("precio")) || 0;
                const precioMayor = parseFloat(opt.data("preciopormayor")) || 0;
                const umbral = parseInt(opt.data("umbral")) || 0;
                const nombre = opt.text();

                if (precioMayor > 0 && umbral > 0 && cantidad >= umbral) {
                    if (parseFloat(row.find(".precio").val()) !== precioMayor) {
                        row.find(".precio").val(precioMayor.toFixed(2));
                        row.addClass("table-success");
                        mostrarToast(`💡 ${nombre}: se aplicó el precio mayorista (S/ ${precioMayor.toFixed(2)})`, "info");
                    }
                } else {
                    if (parseFloat(row.find(".precio").val()) !== precioNormal) {
                        row.find(".precio").val(precioNormal.toFixed(2));
                        row.removeClass("table-success");
                        mostrarToast(`${nombre}: precio normal aplicado (S/ ${precioNormal.toFixed(2)})`, "success");
                    }
                }
            }

            // 🧊 Toast flotante
            function mostrarToast(titulo, tipo) {
                Swal.fire({
                    toast: true,
                    position: "top-end",
                    icon: tipo,
                    title: titulo,
                    showConfirmButton: false,
                    timer: 2300,
                    timerProgressBar: true,
                    background: tipo === "info" ? "#d1e7dd" : "#fff3cd",
                    color: "#000"
                });
            }

            // 💰 Totales
            function actualizarSubtotal(row) {
                const cantidad = parseInt(row.find(".cantidad").val()) || 0;
                const precio = parseFloat(row.find(".precio").val()) || 0;
                const subtotal = cantidad * precio;
                row.find(".subtotal").text(`S/ ${subtotal.toFixed(2)}`);
                actualizarTotal();
            }

            function actualizarTotal() {
                let total = 0;
                tbody.find("tr").each(function () {
                    const cantidad = parseInt($(this).find(".cantidad").val()) || 0;
                    const precio = parseFloat($(this).find(".precio").val()) || 0;
                    total += cantidad * precio;
                });
                $("#total").text(`S/ ${total.toFixed(2)}`);
            }

                    // 📨 Antes de enviar el formulario, agregar los detalles como inputs ocultos
            $("#formCotizacion").on("submit", function (e) {
                // Limpia posibles inputs previos
                $("#formCotizacion input[name^='Detalles']").remove();

                const filas = $("#tablaProductos tbody tr");

                if (filas.length === 0) {
                    e.preventDefault();
                    Swal.fire({
                        icon: "warning",
                        title: "No hay productos agregados",
                        text: "Debes agregar al menos un producto a la cotización.",
                        toast: true,
                        position: "top-end",
                        timer: 2500,
                        showConfirmButton: false
                    });
                    return false;
                }

                filas.each(function (i) {
                    const productoId = $(this).find(".producto").val();
                    const cantidad = $(this).find(".cantidad").val();
                    const precio = $(this).find(".precio").val();

                    // Agregar inputs ocultos al formulario
                    $("<input>", { type: "hidden", name: `Detalles[${i}].ProductoId`, value: productoId }).appendTo("#formCotizacion");
                    $("<input>", { type: "hidden", name: `Detalles[${i}].Cantidad`, value: cantidad }).appendTo("#formCotizacion");
                    $("<input>", { type: "hidden", name: `Detalles[${i}].PrecioUnitario`, value: precio }).appendTo("#formCotizacion");
                });
            });

        });
    </script>

    @* Descargar PDF solo visitantes no logueados *@
    @if (!isLogged)
    {
        <script>
            $("#btnDescargarPdf").on("click", function () {
                const filas = $("#tablaProductos tbody tr");
                if (filas.length === 0) {
                    Swal.fire({
                        icon: "warning",
                        title: "No hay productos",
                        text: "Agrega al menos un producto antes de generar la cotización.",
                        toast: true,
                        position: "top-end",
                        timer: 2500,
                        showConfirmButton: false
                    });
                    return;
                }

                const detalles = [];
                filas.each(function () {
                    detalles.push({
                        Producto: $(this).find(".producto option:selected").text(),
                        Cantidad: parseInt($(this).find(".cantidad").val()) || 0,
                        PrecioUnitario: parseFloat($(this).find(".precio").val()) || 0
                    });
                });

                const data = {
                    Fecha: new Date().toLocaleDateString("es-PE"),
                    VigenteHasta: new Date(Date.now() + 5 * 24 * 60 * 60 * 1000).toLocaleDateString("es-PE"),
                    Total: $("#total").text().replace("S/", "").trim(),
                    Detalles: detalles
                };

                $.ajax({
                    url: '/Cotizacions/GenerarPdf',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    xhrFields: { responseType: 'blob' },
                    success: function (blob) {
                        const url = window.URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url;
                        a.download = `Cotizacion_${Date.now()}.pdf`;
                        a.click();
                        window.URL.revokeObjectURL(url);
                    },
                    error: function () {
                        Swal.fire({
                            icon: "error",
                            title: "Error al generar PDF",
                            text: "No se pudo crear la cotización.",
                            toast: true,
                            position: "top-end",
                            timer: 2500,
                            showConfirmButton: false
                        });
                    }
                });
            });
        </script>
    }
}