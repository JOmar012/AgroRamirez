@model IEnumerable<AgropRamirez.Models.Cotizacion>

@{
    ViewData["Title"] = "Listado de Cotizaciones";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Cotizaciones</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Cotizaciones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Listado</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary"><i class="bi bi-file-earmark-text"></i> Cotizaciones Registradas</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Nueva Cotización
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead class="table-primary text-center">
                    <tr>
                        <th>Código</th>
                        <th>Fecha Cotización</th>
                        <th>Válido Hasta</th>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th style="width: 170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="fw-semibold text-center align-middle">
                            <td>@item.CotizacionId</td>
                            <td>@item.FechaCotizacion.ToString("dd/MM/yyyy")</td>
                            <td>@item.ValidoHasta?.ToString("dd/MM/yyyy")</td>
                            <td>@($"{item.Usuario?.Nombre} {item.Usuario?.Apellido}")</td>
                            <td>S/ @item.Total.ToString("0.00")</td>
                            <td>
                                @switch (item.Estado)
                                {
                                    case "Pendiente":
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Pendiente</span>;
                                        break;
                                    case "Aceptada":
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Aceptada</span>;
                                        break;
                                    case "Rechazada":
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Rechazada</span>;
                                        break;
                                    case "Vencida":
                                        <span class="badge bg-secondary"><i class="bi bi-calendar-x"></i> Vencida</span>;
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">@item.Estado</span>;
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.CotizacionId" class="btn btn-sm btn-info text-white me-1" title="Ver Detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.CotizacionId" class="btn btn-sm btn-warning text-white me-1" title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.CotizacionId" class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </a>

                                @* //Boton descargar pdf *@
                                <a href="javascript:void(0);" class="btn btn-sm btn-outline-primary me-1 btn-descargar" data-id="@item.CotizacionId">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>

                            </td>
                        </tr>

                        <!-- 🔽 Sección de Detalles -->
                        <tr class="bg-light">
                            <td colspan="7" class="p-0">
                                <div class="collapse" id="detalles-@item.CotizacionId">
                                    <div class="p-3">
                                        <h6 class="fw-bold text-secondary mb-3">
                                            <i class="bi bi-list-ul"></i> Productos cotizados:
                                        </h6>

                                        @if (item.CotizacionDetalles != null && item.CotizacionDetalles.Any())
                                        {
                                            <table class="table table-sm table-bordered mb-0">
                                                <thead class="table-secondary text-center">
                                                    <tr>
                                                        <th>Producto</th>
                                                        <th>Precio Unitario</th>
                                                        <th>Cantidad</th>
                                                        <th>Subtotal</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var det in item.CotizacionDetalles)
                                                    {
                                                        <tr class="text-center">
                                                            <td class="text-start">
                                                                <i class="bi bi-caret-right-fill text-primary"></i>
                                                                @det.Producto?.Nombre
                                                            </td>
                                                            <td>S/ @det.PrecioUnitario.ToString("0.00")</td>
                                                            <td>@det.Cantidad</td>
                                                            <td class="fw-bold">S/ @(det.Cantidad * det.PrecioUnitario).ToString("0.00")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <p class="text-muted fst-italic">No hay productos asociados a esta cotización.</p>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>

                        <!-- Botón para expandir/colapsar -->
                        <tr class="border-bottom">
                            <td colspan="7" class="text-center py-2">
                                <button class="btn btn-outline-primary btn-sm toggleDetalles" 
                                        type="button" 
                                        data-bs-toggle="collapse" 
                                        data-bs-target="#detalles-@item.CotizacionId"
                                        aria-expanded="false">
                                    <i class="bi bi-caret-down-square"></i> Ver Detalles
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center mt-3">
                    <i class="bi bi-info-circle"></i> No existen cotizaciones registradas actualmente.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Animación para el botón de expandir/cerrar detalles
        $(".toggleDetalles").on("click", function () {
            const icon = $(this).find("i");
            if (icon.hasClass("bi-caret-down-square")) {
                icon.removeClass("bi-caret-down-square").addClass("bi-caret-up-square");
                $(this).text(" Ocultar Detalles").prepend(icon);
            } else {
                icon.removeClass("bi-caret-up-square").addClass("bi-caret-down-square");
                $(this).text(" Ver Detalles").prepend(icon);
            }
        });
    </script>

    @* //Descragar pdf *@
    <script>
        $(".btn-descargar").on("click", function () {
            const id = $(this).data("id");
            const data = { CotizacionId: id };
            $.ajax({
                url: '/Cotizacions/GenerarPdf',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                xhrFields: { responseType: 'blob' },
                success: function (blob) {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `Cotizacion_${Date.now()}.pdf`;
                    a.click();
                    window.URL.revokeObjectURL(url);
                }
            });
        });
    </script>
}

