@model IEnumerable<AgropRamirez.Models.Cotizacion>
@using System.Security.Claims

@{
    ViewData["Title"] = "Listado de Cotizaciones";
}

@{
var usuarioIdClaim = User.FindFirst("UsuarioId")?.Value;
var rol = User.FindFirst(ClaimTypes.Role)?.Value;
}


<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Cotizaciones</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Cotizaciones</a></li>
                <li class="breadcrumb-item active" aria-current="page">Listado</li>
            </ol>
        </nav>
    </div>
</div>

<!-- ✅ CONTENIDO PRINCIPAL -->
<div class="container mb-5 mt-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">
                    <i class="bi bi-file-earmark-text"></i> Lista de Cotizaciones
                </h4>

                <!-- Botón Nueva Cotización -->
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Nueva Cotización
                </a>
            </div>


            @if (User.Identity.IsAuthenticated)
            {
                <!-- 🔍 FILTROS -->
                <div class="row g-3 bg-light p-3 rounded-3 mb-4 mt-2">

                    <!-- Buscar general -->
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-search"></i> Buscar
                        </label>
                        <input type="text" id="buscarCotizacion" class="form-control"
                               placeholder="Cliente, estado, fecha, total..." />
                    </div>

                    <!-- Estado -->
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-ui-checks"></i> Estado
                        </label>
                        <select id="filtroEstadoCotizacion" class="form-select">
                            <option value="">Todos</option>
                            <option value="pendiente">Pendiente</option>
                            <option value="aceptada">Aceptada</option>
                            <option value="rechazada">Rechazada</option>
                            <option value="vencida">Vencida</option>
                        </select>
                    </div>

                    <!-- Fecha desde -->
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-event"></i> Desde
                        </label>
                        <input type="date" id="fechaDesde" class="form-control" />
                    </div>

                    <!-- Fecha hasta -->
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-check"></i> Hasta
                        </label>
                        <input type="date" id="fechaHasta" class="form-control" />
                    </div>

                    <!-- Botón limpiar -->
                    <div class="col-md-1 d-flex align-items-end">
                        <button id="limpiarCotizacion" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>

                </div>
            }
           

            <div class="table-responsive">
                <table class="table table-custom align-middle text-center" id="tablaCotizaciones">
                    <thead>
                        <tr>
                            @* <th><i class="bi bi-hash"></i> Código</th> *@
                            <th><i class="bi bi-calendar-date"></i> Fecha Cotización</th>
                            <th><i class="bi bi-calendar-check"></i> Válido Hasta</th>
                            <th><i class="bi bi-person-fill"></i> Cliente</th>
                            <th><i class="bi bi-cash-coin"></i> Total</th>
                            <th><i class="bi bi-info-circle-fill"></i> Estado</th>
                            <th><i class="bi bi-gear-fill"></i> Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                @* <td>@item.CotizacionId</td> *@
                                <td>@item.FechaCotizacion.ToString("dd/MM/yyyy")</td>
                                <td>@item.ValidoHasta?.ToString("dd/MM/yyyy")</td>
                                <td>@($"{item.Usuario?.Nombre} {item.Usuario?.Apellido}")</td>
                                <td>S/ @item.Total.ToString("0.00")</td>
                                <td>
                                    @switch (item.Estado)
                                    {
                                        case "Pendiente":
                                            <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Pendiente</span>
                                            ;
                                            break;
                                        case "Aceptada":
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Aceptada</span>
                                            ;
                                            break;
                                        case "Rechazada":
                                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Rechazada</span>
                                            ;
                                            break;
                                        case "Vencida":
                                            <span class="badge bg-secondary"><i class="bi bi-calendar-x"></i> Vencida</span>
                                            ;
                                            break;
                                        default:
                                            <span class="badge bg-light text-dark">@item.Estado</span>
                                            ;
                                            break;
                                    }
                                </td>
                                <td>

                                    <a asp-action="Edit" asp-route-id="@item.CotizacionId" class="btn-icon btn-edit" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.CotizacionId" class="btn-icon btn-details" title="Detalles">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.CotizacionId" class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                    <a href="javascript:void(0);" class="btn-icon btn-download btn-descargar" data-id="@item.CotizacionId" title="Descargar PDF">
                                        <i class="bi bi-file-earmark-pdf-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="alert alert-info text-center mt-3">
                        <i class="bi bi-info-circle"></i> No existen cotizaciones registradas actualmente.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Descargar PDF
        $(".btn-descargar").on("click", function () {
            const id = $(this).data("id");
            const data = { CotizacionId: id };
            $.ajax({
                url: '/Cotizacions/GenerarPdf',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                xhrFields: { responseType: 'blob' },
                success: function (blob) {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `Cotizacion_${Date.now()}.pdf`;
                    a.click();
                    window.URL.revokeObjectURL(url);
                }
            });
        });
    </script>

    @* filtros *@
    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const txtBuscar = document.getElementById("buscarCotizacion");
            const filtroEstado = document.getElementById("filtroEstadoCotizacion");
            const fechaDesde = document.getElementById("fechaDesde");
            const fechaHasta = document.getElementById("fechaHasta");
            const limpiar = document.getElementById("limpiarCotizacion");

            const filas = document.querySelectorAll("#tablaCotizaciones tbody tr");

            function filtrarCotizaciones() {

                let texto = txtBuscar?.value.toLowerCase() || "";
                let estado = filtroEstado?.value.toLowerCase() || "";
                let desde = fechaDesde?.value ? new Date(fechaDesde.value) : null;
                let hasta = fechaHasta?.value ? new Date(fechaHasta.value) : null;

                filas.forEach(fila => {

                    let contenido = fila.innerText.toLowerCase();

                    // Fecha de cotización está en la primera columna
                    let fechaTexto = fila.children[0].innerText.trim();
                    let fecha = new Date(fechaTexto.split("/").reverse().join("-"));

                    let coincideTexto = contenido.includes(texto);
                    let coincideEstado = estado === "" || contenido.includes(estado);
                    let coincideDesde = !desde || fecha >= desde;
                    let coincideHasta = !hasta || fecha <= hasta;

                    if (coincideTexto && coincideEstado && coincideDesde && coincideHasta) {
                        fila.style.display = "";
                    } else {
                        fila.style.display = "none";
                    }
                });
            }

            if (txtBuscar) txtBuscar.addEventListener("keyup", filtrarCotizaciones);
            if (filtroEstado) filtroEstado.addEventListener("change", filtrarCotizaciones);
            if (fechaDesde) fechaDesde.addEventListener("change", filtrarCotizaciones);
            if (fechaHasta) fechaHasta.addEventListener("change", filtrarCotizaciones);

            if (limpiar) {
                limpiar.addEventListener("click", () => {
                    txtBuscar.value = "";
                    filtroEstado.value = "";
                    fechaDesde.value = "";
                    fechaHasta.value = "";
                    filtrarCotizaciones();
                });
            }

        });
    </script>
}