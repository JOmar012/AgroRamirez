@model AgropRamirez.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Eliminar Usuario</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Usuarios</a></li>
                <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header Rojo -->
                <div class="card-header custom-header-delete text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-trash"></i> Confirmar Eliminación
                    </h4>
                </div>

                <div class="card-body p-4">
                    <h5 class="text-center text-danger mb-4">
                        ¿Está seguro que desea eliminar este usuario?
                    </h5>

                    <!-- Ficha con imagen e información -->
                    <div class="row align-items-center">
                        <!-- Imagen -->
                        <div class="col-md-5 text-center mb-3 mb-md-0">
                            <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center">
                                <img src="@(string.IsNullOrEmpty(Model.Imagen) ? Url.Content("~/img/usuarios/default.png") : Model.Imagen)"
                                     alt="Foto del usuario"
                                     class="img-fluid rounded-3 shadow-sm zoom-image"
                                     style="max-height: 250px; object-fit: cover;" />
                            </div>
                        </div>

                        <!-- Información -->
                        <div class="col-md-7">
                            <div>
                                <p><i class="bi bi-person-fill me-2 text-danger"></i><strong>Nombre:</strong> @Model.Nombre</p>
                                <p><i class="bi bi-person-vcard-fill me-2 text-danger"></i><strong>Apellido:</strong> @Model.Apellido</p>
                                <p><i class="bi bi-credit-card-2-front-fill me-2 text-danger"></i><strong>DNI:</strong> @Model.Dni</p>
                                <p><i class="bi bi-envelope-fill me-2 text-danger"></i><strong>Email:</strong> @Model.Email</p>
                                <p><i class="bi bi-person-gear me-2 text-danger"></i><strong>Rol:</strong> @Model.Rol</p>
                                <p><i class="bi bi-calendar-check-fill me-2 text-danger"></i><strong>Registrado:</strong> @Model.FechaRegistro</p>
                            </div>
                        </div>
                    </div>

                    <!-- Botones -->
                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="UsuarioId" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash-fill"></i> Eliminar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>