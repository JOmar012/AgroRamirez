@* @model AgropRamirez.Models.Carrito *@
@model AgropRamirez.ViewModels.CheckoutVM


@{
    ViewData["Title"] = "Crear Carrito";
}


@{
    // ⚙️ Cargar productos desde ViewData (sin tipo para serializar correctamente)
    var productos = ViewData["Productos"];
}



<!-- ======= ENCABEZADO ======= -->
<div class="container-fluid page-header py-5 wow fadeIn" data-wow-delay="0.1s"
     style="background: linear-gradient(rgba(0,0,0,.5), rgba(0,0,0,.5)), url('/img/Campos.jpg') center center/cover no-repeat;">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">
            <i class="bi bi-cart-plus"></i> Crear Carrito para Cliente
        </h1>
        <p class="text-white-50 fs-5 animated fadeIn">
            <i class="bi bi-box-seam"></i> Selecciona el cliente y los productos que deseas agregar al carrito.
        </p>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item active" aria-current="page">Nuevo Carrito</li>
            </ol>
        </nav>
    </div>
</div>

<!-- ======= CONTENIDO PRINCIPAL ======= -->
<div class="container mt-5 mb-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-warning fw-bold d-flex align-items-center">
            <i class="bi bi-person-circle me-2"></i> Registro de Carrito
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- Cliente -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Cliente</label>
                    <select asp-for="UsuarioId" class="form-select" asp-items="ViewBag.UsuarioId" required>
                        <option value="">-- Selecciona un cliente --</option>
                    </select>
                </div>

                <!-- Fecha -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Fecha de creación</label>
                    <input asp-for="FechaCreacion" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                </div>

                <hr />
                <h5 class="text-dark fw-bold mb-3">
                    <i class="bi bi-bag-check"></i> Productos del carrito
                </h5>

                <!-- Tabla de productos -->
                <table class="table table-striped align-middle" id="tablaItems">
                    <thead class="table-dark text-warning">
                        <tr class="text-center">
                            <th style="width:35%">Producto</th>
                            <th style="width:15%">Cantidad</th>
                            <th style="width:20%">Precio (S/)</th>
                            <th style="width:20%">Subtotal (S/)</th>
                            <th style="width:10%"></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

                <!-- Botón agregar -->
                <button type="button" id="btnAgregarItem" class="btn btn-warning fw-bold mb-3">
                    <i class="bi bi-plus-circle"></i> Agregar Producto
                </button>

                <!-- Total -->
                <div class="text-end border-top pt-3">
                    <h5 class="fw-bold text-dark">
                        Total: S/ <span id="totalCarrito">0.00</span>
                    </h5>
                </div>

                @* Volver al listado *@
                <div class="container mb-3">
                    <a asp-action="Index" class="btn btn-outline-dark fw-bold">
                        <i class="bi bi-arrow-left-circle"></i> Volver al listado
                    </a>
                </div>

                <!-- Botón guardar -->
                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-dark fw-bold px-4">
                        <i class="bi bi-save2-fill"></i> Guardar Carrito
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* <div class="container mb-3">
    <a asp-action="Index" class="btn btn-outline-dark fw-bold">
        <i class="bi bi-arrow-left-circle"></i> Volver al listado
    </a>
</div> *@

<!-- ======= SCRIPTS ======= -->
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        // 🔹 Serializamos la lista de productos del servidor
        const productos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(productos));

        console.log("📦 Productos cargados:", productos);

        // =============================================
        // 🔸 Función para reindexar los campos Items[i]
        // =============================================
        function reindexarFilas() {
            const filas = document.querySelectorAll("#tablaItems tbody tr");
            filas.forEach((fila, index) => {
                fila.querySelectorAll("input, select").forEach(input => {
                    if (input.name.includes("Items[")) {
                        input.name = input.name.replace(/Items\[\d+\]/, `Items[${index}]`);
                    }
                });
            });
        }

        // =============================================
        // 🔸 Agregar nueva fila
        // =============================================
        document.getElementById("btnAgregarItem").addEventListener("click", function () {
            const tbody = document.querySelector("#tablaItems tbody");
            const index = tbody.children.length;

            if (!productos || productos.length === 0) {
                Swal.fire({ icon: "warning", title: "No hay productos disponibles", timer: 2000, showConfirmButton: false });
                return;
            }

            let options = "";
            productos.forEach(p => {
                options += `<option value="${p.ProductoId}" data-precio="${p.Precio}" data-stock="${p.Stock}">
                                ${p.Nombre} (Stock: ${p.Stock})
                            </option>`;
            });

            const fila = `
                <tr class="text-center">
                    <td>
                        <select name="Items[${index}].ProductoId" class="form-select producto-select" required>
                            <option value="">-- Selecciona --</option>
                            ${options}
                        </select>
                    </td>
                    <td>
                        <input name="Items[${index}].Cantidad" type="number" min="1" value="1"
                               class="form-control cantidad-input" required />
                    </td>
                    <td>
                        <input name="Items[${index}].PrecioUnitario" type="number" step="0.01"
                               readonly class="form-control precio-input text-center" />
                    </td>
                    <td>
                        <input type="text" readonly class="form-control subtotal-input text-center" value="0.00" />
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger eliminar">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>`;

            tbody.insertAdjacentHTML("beforeend", fila);
            reindexarFilas();
            actualizarEventos();
        });

        // =============================================
        // 🔸 Enlazar eventos dinámicos
        // =============================================
        function actualizarEventos() {
            document.querySelectorAll(".producto-select").forEach(select => {
                select.onchange = function () {
                    const precio = parseFloat(this.selectedOptions[0].dataset.precio) || 0;
                    const fila = this.closest("tr");
                    fila.querySelector(".precio-input").value = precio.toFixed(2);
                    recalcularFila(fila);
                };
            });

            document.querySelectorAll(".cantidad-input").forEach(input => {
                input.oninput = function () {
                    const fila = this.closest("tr");
                    const stock = parseInt(fila.querySelector(".producto-select").selectedOptions[0]?.dataset.stock || 0);
                    const cantidad = parseInt(this.value) || 0;

                    if (cantidad > stock) {
                        Swal.fire({
                            icon: "warning",
                            title: "Stock insuficiente",
                            text: `Solo hay ${stock} unidades disponibles.`,
                            timer: 2000,
                            showConfirmButton: false
                        });
                        this.value = stock;
                    }
                    recalcularFila(fila);
                };
            });

            document.querySelectorAll(".eliminar").forEach(btn => {
                btn.onclick = function () {
                    this.closest("tr").remove();
                    reindexarFilas();
                    recalcularTotal();
                };
            });
        }

        // =============================================
        // 🔸 Calcular subtotal por fila
        // =============================================
        function recalcularFila(fila) {
            const cantidad = parseFloat(fila.querySelector(".cantidad-input").value) || 0;
            const precio = parseFloat(fila.querySelector(".precio-input").value) || 0;
            const subtotal = cantidad * precio;
            fila.querySelector(".subtotal-input").value = subtotal.toFixed(2);
            recalcularTotal();
        }

        // =============================================
        // 🔸 Calcular total general
        // =============================================
        function recalcularTotal() {
            let total = 0;
            document.querySelectorAll(".subtotal-input").forEach(s => {
                total += parseFloat(s.value) || 0;
            });
            document.getElementById("totalCarrito").textContent = total.toFixed(2);
        }
    </script>
}