@model AgropRamirez.Models.Categoria

@{
    ViewData["Title"] = "Eliminar Categoría";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Eliminar Categoría</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Categorías</a></li>
                <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header-delete text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-trash"></i> Eliminar Categoría
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <!-- Avatar -->
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center">
                                <i class="fas fa-horse zoom-avatar-delete"></i>
                            </div>
                        </div>

                        <!-- Contenido -->
                        <div class="col-md-8">
                            <h5 class="text-danger mb-3">
                                <i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación
                            </h5>
                            <p class="text-danger">
                                ¿Estás seguro de que deseas eliminar esta categoría?
                                <strong>Esta acción no se puede deshacer.</strong>
                            </p>

                            <div class="fs-5">
                                <p><i class="bi bi-card-text me-2 text-danger"></i><strong>Nombre:</strong> @Model.Nombre</p>
                                <p><i class="bi bi-journal-text me-2 text-danger"></i><strong>Descripción:</strong> @Model.Descripcion</p>
                            </div>

                            <!-- Formulario de eliminación -->
                            <form asp-action="Delete" method="post" class="mt-4">
                                <input type="hidden" asp-for="CategoriaId" />
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                        <i class="bi bi-arrow-left-circle"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-danger px-4">
                                        <i class="bi bi-trash-fill"></i> Eliminar
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>