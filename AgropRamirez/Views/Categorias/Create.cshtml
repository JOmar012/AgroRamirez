@model AgropRamirez.Models.Categoria

@{
    ViewData["Title"] = "Nueva Categoría";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Nueva Categoría</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Categorías</a></li>
                <li class="breadcrumb-item active" aria-current="page">Crear</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="card-header custom-header text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-plus-circle"></i> Registrar Categoría
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row align-items-center">
                            <!-- Avatar (Caballo) -->
                            <div class="col-md-4 text-center mb-4 mb-md-0">
                                <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center">
                                    <i class="fas fa-horse zoom-avatar"></i>
                                </div>
                            </div>

                            <!-- Formulario -->
                            <div class="col-md-8">
                                <!-- Nombre -->
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                        <input asp-for="Nombre" class="form-control" />
                                    </div>
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>

                                <!-- Descripción -->
                                <div class="mb-3">
                                    <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-journal-text"></i></span>
                                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                                    </div>
                                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left-circle"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle"></i> Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
