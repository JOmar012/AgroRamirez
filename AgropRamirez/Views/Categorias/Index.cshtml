@model IEnumerable<AgropRamirez.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Categorías</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a href="#">Inicio</a></li>
                <li class="breadcrumb-item active" aria-current="page">Categorías</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container mb-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">

            <!-- Header con título y botón -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0"><i class="bi bi-tags-fill"></i> Lista de Categorías</h4>
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-circle-fill"></i> Nueva Categoría
                </a>
            </div>


            <!-- 🔎 Buscador -->
            <form method="get" asp-action="Index" class="mb-3">
                <div class="p-3 bg-light border rounded-3">
                    <div class="row g-3 align-items-end">

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-search"></i> Buscar categoría
                            </label>
                            <input type="text"
                                   name="busqueda"
                                   value="@Context.Request.Query["busqueda"]"
                                   class="form-control"
                                   placeholder="Buscar por nombre o descripción..." />
                        </div>

                        <div class="col-md-3 d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="bi bi-search"></i> Buscar
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary flex-fill">
                                Limpiar
                            </a>
                        </div>

                    </div>
                </div>
            </form>


            <!-- Tabla -->
            <div class="table-responsive">
                <table class="table table-custom align-middle text-center">
                    <thead>
                        <tr>
                            <th><i class="bi bi-card-text"></i> @Html.DisplayNameFor(model => model.Nombre)</th>
                            <th><i class="bi bi-journal-text"></i> @Html.DisplayNameFor(model => model.Descripcion)</th>
                            <th><i class="bi bi-gear-fill"></i> Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                                <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.CategoriaId"
                                       class="btn-icon btn-edit" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.CategoriaId"
                                       class="btn-icon btn-details" title="Detalles">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.CategoriaId"
                                       class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>