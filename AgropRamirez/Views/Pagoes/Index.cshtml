@model IEnumerable<AgropRamirez.Models.Pago>

@{
    ViewData["Title"] = "Listado de Pagos";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 wow fadeIn" data-wow-delay="0.1s"
     style="background: linear-gradient(rgba(0,0,0,.6), rgba(0,0,0,.6)), url('/img/Campos.jpg') center center/cover no-repeat;
            margin-bottom: 3rem;">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">
            <i class="bi bi-cash-coin"></i> Gestión de Pagos
        </h1>
        <p class="text-white-50 fs-5 animated fadeIn">
            <i class="bi bi-wallet2"></i> Administra y controla los pagos realizados por tus clientes.
        </p>
        <nav aria-label="breadcrumb" class="animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
                </li>
                <li class="breadcrumb-item active text-white" aria-current="page">Pagos</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Contenido principal -->
<div class="container mb-5 mt-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">
                    <i class="bi bi-cash-coin"></i> Lista de Pagos
                </h4>

                @* <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Nuevo Pago
                </a> *@

                <!-- Botón Nuevo Pago con SweetAlert -->
                <a href="javascript:void(0);" class="btn btn-success" onclick="mostrarAlertaPago()">
                    <i class="bi bi-plus-circle"></i> Nuevo Pago
                </a>

            </div>

            <div class="table-responsive">
                <table class="table table-custom align-middle text-center">
                    <thead>
                        <tr>
                            <th><i class="bi bi-calendar-date-fill"></i> Fecha de Pago</th>
                            <th><i class="bi bi-cash-stack"></i> Monto</th>
                            <th><i class="bi bi-credit-card-2-front-fill"></i> Método</th>
                            <th><i class="bi bi-check-circle-fill"></i> Estado</th>
                            <th><i class="bi bi-receipt"></i> Pedido</th>
                            <th><i class="bi bi-person-fill"></i> Cliente</th>
                            <th><i class="bi bi-gear-fill"></i> Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FechaPago.ToString("dd/MM/yyyy")</td>
                                <td>S/ @item.Monto.ToString("0.00")</td>
                                <td>@item.MetodoPago</td>
                                <td>
                                    @if (item.Estado == "Pagado")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Pagado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> No Pagado</span>
                                    }
                                </td>
                                <td>@item.Pedido.FechaPedido.ToString("dd/MM/yyyy")</td>
                                <td>@($"{item.Usuario?.Nombre} {item.Usuario?.Apellido}")</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.PagoId" class="btn-icon btn-edit" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.PagoId" class="btn-icon btn-details" title="Detalles">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.PagoId" class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

   @*  Script para regresar a productos *@
    <script>
        function mostrarAlertaPago() {
            Swal.fire({
                title: '¡Atención!',
                text: 'Para realizar un pago primero debes seleccionar productos en el carrito.',
                icon: 'warning',
                confirmButtonText: 'Ir a productos',
                confirmButtonColor: '#198754',
                showCancelButton: true,
                cancelButtonText: 'Cancelar',
                cancelButtonColor: '#6c757d',
                backdrop: true,
                allowOutsideClick: false,
                customClass: {
                    popup: 'rounded-4 shadow-lg'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    // Redirige al Index de Productoes
                    window.location.href = '/Productoes/Index';
                }
            });
        }
    </script>
}