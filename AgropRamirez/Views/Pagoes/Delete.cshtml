@model AgropRamirez.Models.Pago

@{
    ViewData["Title"] = "Eliminar Pago";
}

<!-- Encabezado -->
<div class="container-fluid page-header py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-4 animated slideInDown">Eliminar Pago</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Pagos</a></li>
                <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header custom-header-delete text-center py-3">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-trash"></i> Eliminar Pago
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <!-- Ícono lateral -->
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="ratio ratio-1x1 d-flex justify-content-center align-items-center">
                                <i class="bi bi-wallet2 zoom-avatar-delete text-danger"></i>
                            </div>
                        </div>

                        <!-- Contenido -->
                        <div class="col-md-8">
                            <h5 class="text-danger mb-3">
                                <i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación
                            </h5>
                            <p class="text-muted">
                                ¿Estás seguro de que deseas eliminar este pago?
                                <strong class="text-danger">Esta acción no se puede deshacer.</strong>
                            </p>

                            <!-- Información del pago -->
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Fecha de Pago</dt>
                                <dd class="col-sm-8">@Model.FechaPago.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Monto</dt>
                                <dd class="col-sm-8">S/ @Model.Monto.ToString("0.00")</dd>

                                <dt class="col-sm-4">Método de Pago</dt>
                                <dd class="col-sm-8">@Model.MetodoPago</dd>

                                <dt class="col-sm-4">Estado</dt>
                                <dd class="col-sm-8">@Model.Estado</dd>

                                <dt class="col-sm-4">Pedido</dt>
                                <dd class="col-sm-8">@Model.Pedido.FechaPedido.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Cliente</dt>
                                <dd class="col-sm-8">@($"{Model.Usuario?.Nombre} {Model.Usuario?.Apellido}")</dd>
                            </dl>

                            <!-- Formulario de eliminación -->
                            <form asp-action="Delete" method="post" class="mt-4">
                                <input type="hidden" asp-for="PagoId" />
                                <div class="d-flex justify-content-between">
                                    <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                                        <i class="bi bi-arrow-left-circle"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-danger px-4">
                                        <i class="bi bi-trash-fill"></i> Eliminar
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>