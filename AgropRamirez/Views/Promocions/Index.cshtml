@model IEnumerable<AgropRamirez.Models.Promocion>

@{
    ViewData["Title"] = "Promociones";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 wow fadeIn" data-wow-delay="0.1s"
     style="background: linear-gradient(rgba(0,0,0,.5), rgba(0,0,0,.5)), url('/img/Campos.jpg') center center/cover no-repeat;">
    <div class="container text-center py-5">
        <h1 class="display-3 text-white mb-3 animated slideInDown">
            <i class="bi bi-gift-fill"></i> Promociones Especiales
        </h1>
        <p class="text-white-50 fs-5 animated fadeIn">
            <i class="bi bi-percent"></i> Descuentos exclusivos en productos seleccionados
            <i class="bi bi-cart4"></i>
        </p>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item active" aria-current="page">Promociones</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Carrusel de promociones destacadas -->
<div class="container-fluid py-5 mb-5 wow fadeIn" data-wow-delay="0.1s"
     style="background: linear-gradient(90deg, #c0392b, #e74c3c);">
    <div class="container">

        <!-- Encabezado -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-white mb-0">
                <i class="bi bi-fire"></i> Promociones Destacadas
            </h2>
            @if (User.IsInRole("Administrador"))
            {
                <a asp-action="Create" class="btn btn-warning text-dark fw-bold shadow">
                    <i class="bi bi-plus-circle-fill"></i> Nueva Promoción
                </a>
            }
        </div>

        <!-- Carrusel -->
        <div id="carouselPromociones" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">

                @if (Model != null && Model.Any())
                {
                    var promos = Model.Take(6).ToList(); // máximo 6
                    for (int i = 0; i < promos.Count; i += 3)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="row g-4">
                                @for (int j = i; j < i + 3 && j < promos.Count; j++)
                                {
                                    var promo = promos[j];
                                    <div class="col-lg-4 col-md-6">
                                        <div class="card h-100 shadow-lg border-0 rounded-3 d-flex flex-column text-center promo-card"
                                             data-id="@promo.PromocionId"
                                             style="transition: transform 0.25s ease, box-shadow 0.25s ease;">

                                            <!-- Badge descuento -->
                                            <span class="badge bg-danger position-absolute top-0 start-0 m-2 p-2 fw-bold text-uppercase shadow-sm">
                                                @($"{promo.Descuento:0.#}% Descuento")
                                            </span>

                                            <!-- Imagen -->
                                            <div class="promo-img-wrapper">
                                                <img src="@promo.Imagen"
                                                     alt="@promo.Nombre"
                                                     class="card-img-top promo-img rounded-top"
                                                     style="height: 200px; object-fit: cover;" />
                                            </div>

                                            <!-- Body -->
                                            <div class="card-body flex-grow-1 d-flex flex-column justify-content-between text-start">

                                                <!-- fila superior: info izquierda + botón detalles derecha -->
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <div class="pe-2">
                                                        <h5 class="fw-bold text-dark mb-2">@promo.Nombre</h5>

                                                        @if (promo.Productos != null && promo.Productos.Any())
                                                        {
                                                            <p class="text-muted small mb-0">
                                                                @string.Join(" + ", promo.Productos.Take(3).Select(p => p.Nombre))
                                                                @(promo.Productos.Count > 3 ? "..." : "")
                                                            </p>
                                                        }
                                                        else
                                                        {
                                                            <p class="text-muted small mb-0">Sin productos</p>
                                                        }
                                                    </div>

                                                    <!-- Botón Detalles -->
                                                    <div class="text-end">
                                                        <a asp-action="Details"
                                                           asp-route-id="@promo.PromocionId"
                                                           class="btn btn-outline-success btn-sm fw-bold"
                                                           title="Ver detalles / productos">
                                                            <i class="bi bi-box-seam"></i>
                                                        </a>
                                                    </div>
                                                </div>

                                                <!-- rango de fechas -->
                                                <small class="text-muted d-block mb-3">
                                                    <i class="bi bi-calendar-event"></i>
                                                    Válido: @promo.FechaInicio.ToString("dd/MM/yyyy") - @promo.FechaFin.ToString("dd/MM/yyyy")
                                                </small>

                                                <!-- Botón Añadir promoción -->
                                                @if (promo.Productos != null && promo.Productos.Any())
                                                {
                                                    <button type="button"
                                                            class="btn btn-warning btn-sm fw-bold text-dark btn-add-promo mt-auto w-100 text-center"
                                                            data-id="@promo.PromocionId">
                                                        <i class="bi bi-cart-plus"></i> Añadir promoción
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="carousel-item active">
                        <div class="d-flex justify-content-center align-items-center bg-light" style="min-height:300px;">
                            <h4 class="text-muted">No hay promociones destacadas en este momento</h4>
                        </div>
                    </div>
                }
            </div>

            <!-- Controles -->
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselPromociones" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselPromociones" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>
</div>

<!-- GRID DE TODAS LAS PROMOCIONES -->
<div class="container mb-5">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h3 class="mb-0">
            <i class="bi bi-tags-fill"></i> Todas las Promociones
        </h3>
        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Create" class="btn btn-success shadow">
                <i class="bi bi-plus-circle"></i> Nueva Promoción
            </a>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 shadow-lg border-0 rounded-3 d-flex flex-column position-relative promo-card"
                         data-id="@item.PromocionId"
                         style="transition: transform 0.25s ease, box-shadow 0.25s;">

                        <!-- Badge descuento -->
                        <span class="badge bg-danger position-absolute top-0 start-0 m-2 p-2 fw-bold text-uppercase shadow-sm">
                            @($"{item.Descuento:0.#}% Descuento")
                        </span>

                        <!-- Imagen -->
                        <div class="promo-image-wrapper">
                            <img src="@item.Imagen" alt="@item.Nombre" class="card-img-top promo-image" />
                        </div>

                        <!-- Body -->
                        <div class="card-body text-center flex-grow-1">
                            <h5 class="fw-bold text-dark" style="min-height:48px;">@item.Nombre</h5>

                            @if (item.Productos != null && item.Productos.Any())
                            {
                                <p class="text-muted mb-1">
                                    @string.Join(" + ", item.Productos.Take(2).Select(p => p.Nombre))
                                    @(item.Productos.Count > 2 ? "..." : "")
                                </p>
                            }
                            else
                            {
                                <p class="text-muted mb-1">Sin productos</p>
                            }

                           @*  <small class="text-muted d-block mb-2">
                                <i class="bi bi-calendar-event"></i>
                                Válido: @item.FechaInicio:dd/MM/yyyy - @item.FechaFin:dd/MM/yyyy
                            </small> *@

                            <small class="text-muted d-block mb-2">
                                <i class="bi bi-calendar-event">

                                </i> Válido: @item.FechaInicio.ToString("dd/MM/yyyy") - 
                                @item.FechaFin.ToString("dd/MM/yyyy") </small>

                            @if (User.IsInRole("Cliente"))
                            {
                                @* Detalles *@
                                <a asp-action="Details" asp-route-id="@item.PromocionId"
                                class="btn btn-outline-success btn-sm fw-bold" title="Ver productos">
                                    <i class="bi bi-box-seam"></i>
                                </a>
                            }

                            <!-- Botón añadir promoción -->
                            <button type="button"
                                    class="btn btn-warning btn-sm fw-bold text-dark btn-add-promo"
                                    data-id="@item.PromocionId">
                                <i class="bi bi-cart-plus"></i> Añadir promoción
                            </button>
                        </div>

                        <!-- Footer -->
                        @if (User.IsInRole("Administrador"))
                        {
                            <div class="card-footer bg-white border-0 d-flex justify-content-center gap-2">
                                <a asp-action="Details" asp-route-id="@item.PromocionId"
                                   class="btn btn-outline-success btn-sm fw-bold" title="Ver productos">
                                    <i class="bi bi-box-seam"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.PromocionId"
                                   class="btn btn-outline-warning btn-sm" title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.PromocionId"
                                   class="btn btn-outline-danger btn-sm" title="Eliminar">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h4 class="text-muted">
                <i class="bi bi-info-circle"></i> No hay promociones disponibles en este momento
            </h4>
        </div>
    }
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // 🔹 Redirección al hacer clic en tarjetas de promoción (en cualquier vista)
            document.querySelectorAll(".promo-card").forEach(card => {
                card.addEventListener("click", function (e) {
                    // Evitar conflicto con botones o enlaces
                    if (e.target.closest("button, a, i")) return;

                    const promoId = this.dataset.id;
                    if (promoId) {
                        window.location.href = `/Promocions/Details/${promoId}`;
                    }
                });
            });

        });
    </script>

   
}