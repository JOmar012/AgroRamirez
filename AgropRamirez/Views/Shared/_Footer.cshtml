<!-- Footer Start -->
<div class="container-fluid bg-dark text-light footer mt-5 py-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <div class="row g-5">

            <!-- Ubicación -->
            <div class="col-lg-3 col-md-6">
                <h4 class="text-white mb-4">Ubícanos</h4>
                <p class="mb-2"><i class="fa fa-map-marker-alt me-3"></i>Jr. Revilla Perez 113, Cajamarca, Perú</p>
                <p class="mb-2"><i class="fa fa-phone-alt me-3"></i>+51 976 811 514</p>
                <p class="mb-2"><i class="fa fa-envelope me-3"></i>contacto@agroramirez.com</p>
                <div class="d-flex pt-2">
                    <a class="btn btn-square btn-outline-light rounded-circle me-2" href="#"><i class="fab fa-facebook-f"></i></a>
                    <a class="btn btn-square btn-outline-light rounded-circle me-2" href="#"><i class="fab fa-instagram"></i></a>
                    <a class="btn btn-square btn-outline-light rounded-circle me-2"
                       href="https://wa.me/51976811514" target="_blank">
                        <i class="fab fa-whatsapp"></i>
                    </a>
                </div>
            </div>

            <!-- Servicios -->
            <div class="col-lg-3 col-md-6">
                <h4 class="text-white mb-4">Servicios</h4>
                <a class="btn btn-link" asp-controller="Productoes" asp-action="Index">Insumos agrícolas</a>
                <a class="btn btn-link" asp-controller="Promocions" asp-action="Index">Promociones</a>
                @{
                    string controller = "Cotizacions";
                    string action = "Create";

                    if (User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Administrador") || User.IsInRole("Cliente"))
                        {
                            action = "Index";
                        }
                    }
                }

                <a class="btn btn-link" asp-controller="@controller" asp-action="@action">
                    Cotizaciones
                </a>
                @if (User.Identity.IsAuthenticated)
                {
                    if (User.IsInRole("Administrador"))
                    {
                        <a class="btn btn-link" asp-controller="Carritoes" asp-action="Index">Carrito de compras</a>
                    }
                    else if (User.IsInRole("Cliente"))
                    {
                        <a class="btn btn-link" asp-controller="Carritoes" asp-action="MiCarrito">Carrito de compras</a>
                    }
                }
                else
                {
                    <a class="btn btn-link" asp-controller="Productoes" asp-action="Index">Carrito de compras</a>
                }
            </div>

            <!-- Enlaces rápidos -->
            <div class="col-lg-3 col-md-6">
                <h4 class="text-white mb-4">Enlaces rápidos</h4>
                <a class="btn btn-link" asp-controller="Home" asp-action="About">Nosotros</a>
                <a class="btn btn-link" asp-controller="Home" asp-action="Contact">Contáctanos</a>
                <a class="btn btn-link" asp-controller="Home" asp-action="Service">Servicios</a>
                <a class="btn btn-link" href="#">Términos y condiciones</a>
                <a class="btn btn-link" href="#">Soporte</a>
            </div>

            <!-- Newsletter -->
            <div class="col-lg-3 col-md-6">
                <h4 class="text-white mb-4">Boletín</h4>
                <p>Suscríbete para recibir novedades, promociones y consejos del sector agropecuario.</p>
                <div class="position-relative w-100">
                    <input class="form-control bg-light border-light w-100 py-3 ps-4 pe-5" type="text" placeholder="Tu correo electrónico">
                    <button type="button" class="btn btn-primary py-2 position-absolute top-0 end-0 mt-2 me-2">Suscribirse</button>
                </div>
            </div>

        </div>
    </div>
</div>
<!-- Footer End -->
